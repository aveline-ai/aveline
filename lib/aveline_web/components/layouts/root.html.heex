<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Aveline">
      {assigns[:page_title]}
    </.live_title>
    <meta property="og:site_name" content="Aveline" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={assigns[:og_title] || assigns[:page_title] || "Aveline"} />
    <meta
      property="og:description"
      content={assigns[:og_description] || "Notion for AI agents: the shared knowledge base teams and their agents read and write together."}
    />
    <meta :if={assigns[:noindex]} name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href={~p"/favicon-96x96.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,500;9..144,600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css"
    />
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <script>
      window.Prism = window.Prism || {};
      window.Prism.manual = true;

      // Apply the saved sidebar-collapsed state before paint to avoid a
      // expand-then-collapse flash on load. Falls back to viewport width
      // when the user hasn't expressed a preference yet.
      (function () {
        var pref = localStorage.getItem("aveline:sidebarCollapsed");
        var collapsed = pref === "1" || (pref === null && window.innerWidth < 1024);
        if (collapsed) document.documentElement.classList.add("sidebar-collapsed");
      })();
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
    <style>
      :root {
        /* Linear-style monochrome surfaces.
           sidebar (#070707) < bg (#0F1010) < comment card (#171718). */
        --bg: #0F1010;
        --bg-elevated: #070707;
        --bg-card: #171718;
        --bg-card-hover: #1B1C1C;
        --bg-input: #0A0A0A;
        --border: rgba(255,255,255,0.06);
        --border-strong: rgba(255,255,255,0.10);
        --text: #E8E8EA;
        --text-secondary: #A8A9B0;
        --text-muted: #696970;
        /* Single accent: a calm system-blue. Used ONLY for primary actions,
           active nav, links, and focus rings. Everything else stays mono. */
        --accent: #3B82F6;
        --accent-hover: #4F8EF7;
        --accent-dim: rgba(59,130,246,0.14);
        /* Tag chips default to neutral grey — color is reserved for
           tags with a user-chosen color (per-chip --tag override). */
        --tag: #A9AFB8;
        --tag-dim: rgba(169,175,184,0.07);
        --tag-border: rgba(169,175,184,0.24);
        /* Attention amber — the needs-you inbox, independent of tags. */
        --attn: #E09150;
        --attn-dim: rgba(224,145,80,0.08);
        --attn-border: rgba(224,145,80,0.22);
        --author: #B8A78F;
        --author-dim: rgba(184,167,143,0.08);
        --author-border: rgba(184,167,143,0.24);
        --danger: #E5484D;
        --radius-sm: 4px;
        --radius: 6px;
        --radius-lg: 8px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; }
      /* Kill mobile-browser font boosting — it inflates dense text
         (menu descriptions, card summaries) past the authored scale. */
      html { -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 14px;
        line-height: 1.5;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-feature-settings: "cv11", "ss01";
      }
      code, pre, .mono {
        font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
      a { color: inherit; text-decoration: none; }
      input, textarea { font: inherit; color: inherit; }

      /* ===== App shell ===== */
      .shell { display: flex; flex-direction: column; min-height: 100vh; }
      .shell-sidebar { display: flex; flex-direction: row; min-height: 100vh; }

      /* ===== Sidebar ===== */
      .sidebar {
        width: 232px; flex-shrink: 0;
        background: var(--bg-elevated);
        border-right: 1px solid var(--border);
        display: flex; flex-direction: column;
        padding: 8px;
        /* dvh, not vh: mobile 100vh is the large viewport, which makes a
           sticky sidebar taller than the screen — it then scrolls with
           the page and pushes the footer below the fold. */
        height: 100vh;
        height: 100dvh;
        position: sticky; top: 0;
        overflow-y: auto;
      }
      /* ===== Workspace switcher (uses <details> for native click-away) ===== */
      .workspace-switcher { position: relative; }
      .workspace-switcher > summary {
        list-style: none;
        cursor: pointer;
        user-select: none;
      }
      .workspace-switcher > summary::-webkit-details-marker { display: none; }
      .sidebar-header {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 8px 10px;
        margin-bottom: 4px;
        border-radius: 6px;
        transition: background 0.08s ease;
      }
      .workspace-switcher > summary:hover .sidebar-header { background: rgba(255,255,255,0.03); }
      .workspace-switcher[open] > summary .sidebar-header { background: rgba(255,255,255,0.05); }
      .sidebar-workspace {
        flex: 1; min-width: 0;
        font-weight: 500; font-size: 13px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .sidebar-header-chev {
        width: 12px; height: 12px;
        color: var(--text-muted);
        flex-shrink: 0;
        transition: transform 0.12s ease;
      }
      .workspace-switcher[open] .sidebar-header-chev { transform: rotate(180deg); }

      .switcher-menu {
        position: absolute;
        top: calc(100% + 4px); left: 0;
        width: calc(100% + 0px);
        background: var(--bg-elevated);
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        padding: 4px;
        box-shadow: 0 10px 24px rgba(0,0,0,0.5);
        z-index: 20;
      }
      .switcher-label {
        padding: 6px 8px 4px;
        font-size: 10.5px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--text-muted);
      }
      .switcher-item {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 8px; border-radius: 5px;
        font-size: 13px; color: var(--text-secondary);
        line-height: 18px;
      }
      .switcher-item:hover { background: rgba(255,255,255,0.05); color: var(--text); }
      .switcher-item.current { color: var(--text); }
      .switcher-item .check {
        margin-left: auto;
        color: var(--accent);
        font-size: 12px;
      }
      .switcher-item-meta { font-size: 11px; color: var(--text-muted); }
      .switcher-divider {
        height: 1px; background: var(--border);
        margin: 4px -4px;
      }
      .sidebar-section { margin-bottom: 4px; }
      .sidebar-label {
        font-size: 10.5px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--text-muted);
        padding: 12px 8px 4px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .sidebar-item {
        display: flex; align-items: center; gap: 8px;
        padding: 5px 8px; border-radius: 5px;
        font-size: 13px; font-weight: 400; color: var(--text-secondary);
        margin: 1px 0;
        line-height: 18px;
      }
      .sidebar-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
      .sidebar-item.active {
        background: rgba(255,255,255,0.07);
        color: var(--text); font-weight: 500;
      }
      .sidebar-item .icon {
        width: 14px; height: 14px;
        opacity: 0.7; flex-shrink: 0;
        color: var(--text-muted);
      }
      .sidebar-item:hover .icon, .sidebar-item.active .icon {
        color: var(--text-secondary); opacity: 1;
      }
      .sidebar-item.active .icon { color: var(--accent); }
      .sidebar-item .label {
        flex: 1; min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .sidebar-item .count {
        font-size: 11px; color: var(--text-muted);
        font-variant-numeric: tabular-nums;
      }
      .sidebar-item .pin-dot {
        width: 5px; height: 5px; border-radius: 50%;
        background: var(--accent); flex-shrink: 0;
      }
      .sidebar-spacer { flex: 1; }
      .sidebar-footer {
        padding: 8px;
        border-top: 1px solid var(--border);
        margin: 8px -8px 0;
      }
      .sidebar-user {
        display: flex; align-items: center; gap: 8px;
        padding: 4px;
      }
      .sidebar-user .name {
        flex: 1; font-size: 13px; color: var(--text);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .sidebar-user a {
        font-size: 12px; color: var(--text-muted);
      }
      .sidebar-user a:hover { color: var(--text); }

      /* ===== Sidebar collapse toggle =====
         Floats on the sidebar's right edge as a small circular chevron,
         half poking out into the main content. Linear/Notion pattern —
         no full-width sidebar row, just a quiet edge handle. */
      .shell-sidebar { position: relative; }
      .sidebar-edge-toggle {
        position: fixed;
        top: 50%;
        left: 220px;     /* sidebar 232 − half of 24px button = 220 */
        transform: translateY(-50%);
        z-index: 20;
        width: 22px; height: 22px;
        border-radius: 50%;
        background: var(--bg-elevated);
        border: 1px solid var(--border-strong);
        display: inline-flex; align-items: center; justify-content: center;
        color: var(--text-muted);
        cursor: pointer;
        padding: 0;
        opacity: 0;
        transition: left 0.18s ease, color 0.1s ease, background 0.1s ease, opacity 0.12s ease, border-color 0.1s ease;
      }
      .sidebar-edge-toggle svg { width: 13px; height: 13px; }
      .sidebar-edge-toggle:hover {
        color: var(--text);
        background: var(--bg-card-hover);
        border-color: var(--text-muted);
      }
      .shell-sidebar:hover .sidebar-edge-toggle,
      .sidebar-edge-toggle:focus-visible { opacity: 1; }
      html.sidebar-collapsed .sidebar-edge-toggle {
        left: 44px;     /* collapsed sidebar 56 − 12 */
        opacity: 1;     /* keep it visible when collapsed so users can re-expand */
      }
      .sidebar-edge-toggle-expand { display: none; }
      html.sidebar-collapsed .sidebar-edge-toggle-collapse { display: none; }
      html.sidebar-collapsed .sidebar-edge-toggle-expand { display: inline-block; }

      /* ===== Collapsed sidebar =====
         Source of truth: `html.sidebar-collapsed`. CSS shrinks the
         sidebar to icon width and hides every text element. Tooltips
         (native `title=`) cover the lost labels. */
      html.sidebar-collapsed .sidebar {
        width: 56px;
        padding: 8px 6px;
      }
      html.sidebar-collapsed .sidebar-header {
        padding: 6px 4px 10px;
        gap: 0;
        justify-content: center;
      }
      html.sidebar-collapsed .sidebar-workspace,
      html.sidebar-collapsed .sidebar-header-chev { display: none; }
      html.sidebar-collapsed .sidebar-item {
        justify-content: center;
        padding: 8px 0;
      }
      html.sidebar-collapsed .sidebar-item .label,
      html.sidebar-collapsed .sidebar-item .count { display: none; }
      html.sidebar-collapsed .sidebar-label,
      html.sidebar-collapsed .sidebar-user .name { display: none; }
      html.sidebar-collapsed .sidebar-footer {
        padding: 4px 0;
        margin: 8px 0 0;     /* drop the negative side margins so the
                                 footer doesn't overflow the narrow column */
      }
      html.sidebar-collapsed .sidebar-user { justify-content: center; padding: 0; }
      /* Logout link: text label when expanded, icon when collapsed. */
      .sidebar-logout-icon { display: none; }
      .sidebar-logout-icon { width: 16px; height: 16px; }
      html.sidebar-collapsed .sidebar-logout {
        display: inline-flex; align-items: center; justify-content: center;
        width: 28px; height: 28px;
        border-radius: 5px;
        color: var(--text-muted);
      }
      html.sidebar-collapsed .sidebar-logout:hover {
        color: var(--text); background: rgba(255,255,255,0.04);
      }
      html.sidebar-collapsed .sidebar-logout-text { display: none; }
      html.sidebar-collapsed .sidebar-logout-icon { display: inline-block; }
      /* When collapsed, the workspace switcher menu would be clipped by
         the narrow sidebar's overflow. Pop it out as a fixed-position
         floater anchored to the brand mark's right edge. */
      html.sidebar-collapsed .switcher-menu {
        position: fixed;
        top: 12px;
        left: 60px;
        min-width: 220px;
        width: auto;
        z-index: 30;
      }

      /* ===== Main area (with sidebar) ===== */
      .main-wrap {
        flex: 1; min-width: 0;
        display: flex; flex-direction: column;
      }
      .topbar {
        height: 48px; padding: 0 28px;
        display: flex; align-items: center; gap: 12px;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        position: sticky; top: 0; z-index: 10;
      }
      .topbar-title {
        font-size: 14px; font-weight: 500;
        display: flex; align-items: center; gap: 8px;
      }
      .topbar-spacer { flex: 1; }
      .topbar-meta {
        font-size: 12px; color: var(--text-muted);
        display: flex; align-items: center; gap: 8px;
      }
      /* Canonical page container. Every in-app LV renders into a `.content`
         div so the chrome-to-content distance is identical when switching
         tabs on wide monitors. Padding constants kept tight so the centered
         column doesn't drift on smaller screens. */
      .content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 48px 28px 80px;
        flex: 1;
        width: 100%;
      }
      /* Reading-width inner section for forms / long-form copy. Sits
         inside `.content` and keeps line length comfortable. */
      .content-section-narrow {
        max-width: 720px;
      }

      .nav {
        position: sticky; top: 0; z-index: 10;
        display: flex; align-items: center; gap: 12px;
        height: 48px; padding: 0 20px;
        background: rgba(8,9,10,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-brand {
        display: flex; align-items: center; gap: 8px;
        font-weight: 600; font-size: 14px; letter-spacing: -0.01em;
      }
      .nav-brand-mark {
        width: 22px; height: 22px;
        background-image: url("/favicon.svg");
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
        flex-shrink: 0;
        /* Hide any text inside (the literal "A" letter we still pass for
           backwards compat with old templates) — only the SVG shows. */
        font-size: 0; color: transparent;
      }
      .brand-wordmark {
        font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
        font-weight: 500; letter-spacing: -0.01em;
      }
      .nav-sep { color: var(--text-muted); font-size: 12px; }
      .nav-crumb {
        color: var(--text-secondary); font-weight: 500;
        max-width: 240px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .nav-crumb:hover { color: var(--text); }
      .nav-crumb-current {
        color: var(--text); font-weight: 500;
        max-width: 320px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .nav-spacer { flex: 1; }
      .nav-user { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text-secondary); }
      .nav-user .avatar {
        width: 22px; height: 22px; border-radius: 50%;
        background: var(--accent-dim); color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 600;
      }
      .nav-user a { color: var(--text-muted); }
      .nav-user a:hover { color: var(--text); }

      /* ===== Page layout ===== */
      main { flex: 1; width: 100%; }

      /* ===== Headers ===== */
      .page-eyebrow {
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 8px;
      }
      h1.page-title {
        font-size: 28px; font-weight: 600; letter-spacing: -0.02em;
        margin-bottom: 10px;
      }
      .page-subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 44px; }

      /* ===== Section labels ===== */
      .section-label {
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        margin: 24px 0 12px;
        display: flex; align-items: center; gap: 8px;
      }
      .section-label .count {
        color: var(--text-muted); font-weight: 400;
        background: var(--bg-card); padding: 1px 6px; border-radius: 999px;
        font-size: 10px;
      }

      /* ===== Cards ===== */
      .card-list { display: flex; flex-direction: column; gap: 4px; list-style: none; }
      .card {
        display: block; padding: 12px 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--bg-card);
        transition: background 0.08s ease, border-color 0.08s ease;
        position: relative;
      }
      .card:hover { background: var(--bg-card-hover); border-color: var(--border-strong); }
      .card-title {
        font-weight: 500; font-size: 14px; color: var(--text);
        display: flex; align-items: center; gap: 8px;
      }
      .card-summary {
        font-size: 13px; color: var(--text-secondary);
        margin-top: 4px;
        overflow: hidden; text-overflow: ellipsis;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      }
      .card-meta {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-top: 10px; font-size: 12px; color: var(--text-muted);
      }
      .card-slug { font-size: 11px; color: var(--text-muted); }
      .card-meta-dot { color: var(--text-muted); opacity: 0.5; }
      .card-date {
        display: inline-flex; align-items: center; gap: 4px;
      }
      .card-date svg { width: 13px; height: 13px; opacity: 0.7; }
      .card-stat {
        display: inline-flex; align-items: center; gap: 4px;
        color: var(--text-muted);
        font-variant-numeric: tabular-nums;
      }
      .card-stat svg { width: 12px; height: 12px; opacity: 0.75; }

      /* ===== Actor icon (human / agent) ===== */
      .actor-icon {
        width: 14px; height: 14px;
        color: var(--text-muted);
        flex-shrink: 0;
        display: inline-block; vertical-align: -2px;
      }
      .actor-icon-sm { width: 12px; height: 12px; }
      .owner-chip {
        display: inline-flex; align-items: center; gap: 6px;
        color: var(--text-secondary); font-size: 12px;
      }

      /* ===== Filter status ===== */
      .filter-status {
        display: flex; align-items: center; gap: 12px;
        font-size: 12px; color: var(--text-muted);
        margin-bottom: 12px;
      }
      .filter-status .clear {
        color: var(--accent); cursor: pointer;
        text-decoration: underline; text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }
      .filter-status .clear:hover { color: var(--text); }

      /* ===== Tooltip (browser-native via title attr) — no extra CSS ===== */


      /* ===== Chips ===== */
      .chip {
        display: inline-flex; align-items: center; gap: 6px;
        height: 22px; padding: 0 8px;
        border-radius: 4px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        font-size: 11.5px; color: var(--text-secondary);
        font-weight: 500;
        letter-spacing: 0.01em;
      }
      .chip:hover { color: var(--text); border-color: var(--border-strong); }
      /* Badge categories — same shape (`.chip` base), different palette.
         Tag = subtle orange. Author = subtle teal. Distinct from the
         blue CTA accent so categories scan at a glance. */
      .chip-tag {
        background: var(--tag-dim);
        border-color: var(--tag-border);
        color: var(--tag);
      }
      .chip-tag:hover { color: var(--tag); border-color: var(--tag); }
      .chip-author {
        background: var(--author-dim);
        border-color: var(--author-border);
        color: var(--author);
      }
      .chip-author:hover { color: var(--author); border-color: var(--author); }
      /* Actor glyph inside an author chip inherits the bolder author hue
         instead of the muted gray it uses elsewhere. */
      .chip-author .actor-icon { color: var(--author); opacity: 0.95; }
      /* Active chip = bolder version of the same kind color. We keep the
         palette (orange for tags, lavender for authors) and just punch up
         the border + text so the selection reads firm without flipping
         to a jarring white fill. */
      .chip-tag.chip-active {
        background: var(--tag-dim);
        border-color: var(--tag);
        color: var(--tag);
        font-weight: 600;
      }
      .chip-tag.chip-active:hover { background: var(--tag-dim); border-color: var(--tag); color: var(--tag); }
      .chip-author.chip-active {
        background: var(--author-dim);
        border-color: var(--author);
        color: var(--author);
        font-weight: 600;
      }
      .chip-author.chip-active:hover { background: var(--author-dim); border-color: var(--author); color: var(--author); }
      /* Trailing badge on each chip: a tabular-numbers count when
         unselected, a dot when selected. Width is held constant so chips
         don't resize when toggled — the row stays the same length. */
      .chip-meta {
        margin-left: 4px;
        min-width: 14px;
        text-align: center;
        opacity: 0.55;
        font-variant-numeric: tabular-nums;
        display: inline-block;
      }
      .chip-active .chip-meta { opacity: 0.9; }
      /* Disabled chip: tag/author exists but the current filter has no
         docs that also carry it. Same frame as a real chip — just dimmer
         tones — so the row stays visually consistent. */
      .chip-disabled {
        color: var(--text-muted);
        background: rgba(255,255,255,0.02);
        border-color: var(--border-strong);
        cursor: not-allowed;
      }
      .chip-disabled:hover {
        color: var(--text-muted);
        background: rgba(255,255,255,0.02);
        border-color: var(--border-strong);
      }
      .chip-row { display: flex; flex-wrap: wrap; gap: 6px; }

      /* ===== Tabs ===== */
      .tabs {
        display: flex; gap: 4px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 24px;
      }
      .tab {
        padding: 8px 12px; font-size: 13px; font-weight: 500;
        color: var(--text-muted);
        border-bottom: 1.5px solid transparent;
        margin-bottom: -1px;
      }
      .tab:hover { color: var(--text-secondary); }
      .tab-active { color: var(--text); border-bottom-color: var(--accent); }
      .tab .count {
        margin-left: 6px; font-size: 11px;
        color: var(--text-muted); font-weight: 400;
      }

      /* ===== Filter bar ===== */
      .filter-bar {
        display: flex; flex-direction: column; gap: 10px;
        margin-bottom: 16px;
      }
      /* Each filter row is icon + content, vertically aligned. The icon
         is muted and acts as a category cue (tag / author / sort). */
      .filter-row {
        display: flex; align-items: flex-start; gap: 10px;
      }
      .filter-row-icon {
        flex-shrink: 0;
        width: 22px; height: 22px;
        display: inline-flex; align-items: center; justify-content: center;
        color: var(--text-muted);
        margin-top: 3px;
      }
      .filter-row-icon svg { width: 14px; height: 14px; }
      .filter-row > .chip-row,
      .filter-row > .seg-row,
      .filter-row > .filter-row-form { flex: 1; min-width: 0; }
      .filter-row-form { display: flex; }
      .filter-row-form .search-input { flex: 1; }
      /* Segmented control — connected buttons sharing borders. One container
         per segment (pin-mode = triple, sort = double). The active button is
         filled, others are quiet. Buttons share edges, no gaps between. */
      .seg-row { display: flex; flex-wrap: wrap; gap: 12px; }
      .seg {
        display: inline-flex;
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        overflow: hidden;
      }
      .seg-btn {
        font-size: 12px; font-weight: 500;
        color: var(--text-muted);
        padding: 6px 12px;
        background: transparent;
        border: none;
        border-radius: 0;
        transition: color 0.08s ease, background 0.08s ease;
      }
      .seg-btn + .seg-btn { border-left: 1px solid var(--border-strong); }
      .seg-btn:hover { color: var(--text); background: rgba(255,255,255,0.03); }
      /* Active segment is a neutral fill — blue is reserved for the
         primary CTA so toggles don't compete for attention. */
      .seg-btn-active {
        background: rgba(255,255,255,0.07);
        color: var(--text);
      }
      .seg-btn-active:hover { background: rgba(255,255,255,0.09); color: var(--text); }
      .search-input {
        width: 100%;
        height: 36px; padding: 0 12px;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        font-size: 13px;
        color: var(--text);
        outline: none;
        transition: border-color 0.08s ease;
      }
      .search-input::placeholder { color: var(--text-muted); }
      .search-input:focus { border-color: var(--accent); }

      /* ===== Article (doc detail) ===== */
      .article-header { margin-bottom: 0; }
      .article-title-row {
        display: flex; align-items: flex-start; gap: 2px;
        margin-bottom: 4px;
      }
      /* Same scale as h1.page-title so doc pages sit in the same type
         system as every list page. */
      .article-title {
        flex: 1; min-width: 0;
        font-size: 28px; font-weight: 600; letter-spacing: -0.02em;
        line-height: 1.2;
        margin: 0 10px 0 0;
      }

      /* Kudos toggle — icon-only, no count (no social-proof bias). */
      .article-kudos-btn {
        flex-shrink: 0;
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px;
        margin-top: 4px;
        border: none; background: transparent;
        border-radius: 8px;
        color: var(--text-muted);
        cursor: pointer;
        transition: color 0.1s ease, background 0.1s ease, transform 0.06s ease;
      }
      .article-kudos-btn svg {
        width: 20px; height: 20px;
        fill: none; stroke: currentColor;
        transition: fill 0.1s ease, color 0.1s ease;
      }
      .article-kudos-btn:hover {
        color: var(--text);
        background: rgba(255,255,255,0.05);
      }
      .article-kudos-btn:active { transform: scale(0.94); }
      .article-kudos-btn.is-given { color: var(--text); }
      .article-kudos-btn.is-given svg { fill: currentColor; }
      .article-kudos-btn.is-static { cursor: default; }
      .article-kudos-btn.is-static:hover { background: transparent; color: var(--text-muted); }
      .article-summary { color: var(--text-secondary); font-size: 15px; margin-bottom: 4px; }
      .article-meta {
        display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
        font-size: 12.5px; color: var(--text-muted);
      }
      .article-meta-item { display: inline-flex; align-items: center; gap: 6px; }
      .article-meta-key { color: var(--text-muted); }
      .article-meta-val { color: var(--text-secondary); }

      /* ===== Prose (rendered markdown) ===== */
      .prose { font-size: 15px; line-height: 1.7; color: var(--text); padding-top: 4px; }
      .prose > * + * { margin-top: 16px; }
      .prose h1 { font-size: 24px; font-weight: 600; letter-spacing: -0.01em; margin-top: 32px; }
      .prose h2 {
        font-size: 18px; font-weight: 600; letter-spacing: -0.01em;
        margin-top: 32px; padding-bottom: 6px;
        border-bottom: 1px solid var(--border);
      }
      .prose h3 { font-size: 15px; font-weight: 600; margin-top: 24px; }
      .prose p { color: var(--text); }
      .prose a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
      .prose a:hover { text-decoration-thickness: 2px; }
      .prose ul, .prose ol { padding-left: 22px; }
      .prose li + li { margin-top: 4px; }
      .prose code {
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px;
        background: var(--bg-card);
        padding: 1.5px 5px; border-radius: 3px;
        border: 1px solid var(--border);
      }
      .prose pre {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 14px 16px;
        overflow-x: auto;
        font-size: 12.5px; line-height: 1.55;
      }
      .prose pre code { background: none; border: none; padding: 0; font-size: inherit; }
      .prose blockquote {
        border-left: 2px solid var(--accent);
        padding: 4px 0 4px 16px;
        color: var(--text-secondary);
      }
      .prose table {
        width: 100%; border-collapse: collapse;
        font-size: 13px;
        border: 1px solid var(--border); border-radius: var(--radius);
        overflow: hidden;
      }
      .prose th, .prose td {
        text-align: left; padding: 8px 12px;
        border-bottom: 1px solid var(--border);
      }
      .prose th {
        background: var(--bg-card);
        font-weight: 600; color: var(--text-secondary);
        font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em;
      }
      .prose tr:last-child td { border-bottom: none; }
      .prose hr { border: none; height: 1px; background: var(--border); margin: 24px 0; }

      /* ===== Blocks renderer ===== */
      .blocks > * + * { margin-top: 16px; }
      .blk-anchored { position: relative; }
      .block-gutter {
        position: absolute;
        left: -52px;
        top: 0;
        height: 1lh;
        display: inline-flex; align-items: center; gap: 2px;
      }
      .blk-anchored:hover > .block-gutter > * { opacity: 1; }
      .blk-anchored:hover > .block-gutter > .block-anchor { opacity: 1; }
      .block-comment-btn {
        width: 22px; height: 22px;
        display: inline-flex; align-items: center; justify-content: center;
        color: var(--text-muted);
        border-radius: 4px;
        opacity: 0;
        transition: opacity 0.1s ease, color 0.1s ease, background 0.1s ease;
        background: transparent;
        padding: 0;
      }
      .block-comment-btn svg { width: 13px; height: 13px; }
      .block-comment-btn:hover { color: var(--accent); background: rgba(255,255,255,0.05); }
      .block-anchor {
        position: relative;
        left: 0;
        top: 0;
        /* 1lh = one line-height of the host block, so a heading's anchor
           is exactly one heading-line tall and centers its icon on the
           first text line. Works uniformly across h1/h2/h3/p/list/code. */
        height: 1lh;
        width: 22px;
        display: inline-flex; align-items: center; justify-content: center;
        color: var(--text-muted);
        border-radius: 4px;
        opacity: 0;
        transition: opacity 0.1s ease, color 0.1s ease, background 0.1s ease;
        text-decoration: none;
      }
      .block-anchor svg { width: 13px; height: 13px; }
      .block-anchor:hover { color: var(--accent); background: rgba(255,255,255,0.05); }
      .block-anchor.copied { color: var(--accent); opacity: 1; }
      /* Code wrapper's font is monospace 13px line-height ~1.6 — still 1lh works. */
      .blk-code-wrap { position: relative; }
      .blk-table-wrap.blk-anchored > .block-gutter { top: 4px; }
      /* Lists put list-style markers in the left padding (~22px); shift the
         gutter further out so it doesn't sit over the bullet. */
      .blk-list.blk-anchored > .block-gutter { left: -74px; }
      /* scroll under the sticky topbar (48px) when jumping to a block */
      .blocks [id] { scroll-margin-top: 64px; }
      @keyframes blk-target-flash {
        0%   { background-color: rgba(120, 119, 255, 0.22); }
        100% { background-color: transparent; }
      }
      .blk-target-flash {
        animation: blk-target-flash 1.6s ease-out;
        border-radius: 4px;
      }
      .blocks .blk-h1 { font-size: 26px; font-weight: 600; letter-spacing: -0.015em; margin-top: 32px; }
      .blocks .blk-h2 {
        font-size: 18px; font-weight: 600; letter-spacing: -0.01em;
        margin-top: 32px; padding-bottom: 6px;
        border-bottom: 1px solid var(--border);
      }
      .blocks .blk-h3 { font-size: 15px; font-weight: 600; margin-top: 24px; }
      .blocks .blk-p { font-size: 15px; line-height: 1.7; color: var(--text); }
      .blocks .blk-list { padding-left: 22px; font-size: 15px; line-height: 1.7; }
      .blocks .blk-list li + li { margin-top: 4px; }
      .blocks .blk-code {
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 14px 16px; overflow-x: auto;
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px; line-height: 1.55;
      }
      .blocks .blk-code { position: relative; padding-top: 28px; }
      /* Override Prism Tomorrow so our card background + padding wins. */
      .blocks pre.blk-code[class*="language-"],
      .blocks pre.blk-code {
        background: var(--bg-card) !important;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 28px 16px 14px !important;
        margin: 0;
        text-shadow: none;
      }
      .blocks .blk-code code,
      .blocks .blk-code code[class*="language-"] {
        background: none !important;
        padding: 0 !important;
        border: none !important;
        text-shadow: none;
        font-family: 'JetBrains Mono', monospace !important;
        font-size: 12.5px;
        line-height: 1.55;
        color: var(--text);
      }
      .blocks .blk-code::before {
        content: attr(data-lang);
        position: absolute;
        top: 8px; left: 16px;
        font-size: 10.5px; text-transform: uppercase;
        letter-spacing: 0.08em; color: var(--text-muted);
        font-family: 'Inter', sans-serif;
      }
      .blocks .blk-code[data-lang=""] { padding-top: 14px; }
      .blocks .blk-code[data-lang=""]::before { content: none; }
      .blocks .blk-table-wrap { overflow-x: auto; }
      .blocks .blk-table {
        width: 100%; border-collapse: collapse;
        font-size: 13px;
        border: 1px solid var(--border); border-radius: var(--radius);
        overflow: hidden;
      }
      .blocks .blk-table th, .blocks .blk-table td {
        text-align: left; padding: 8px 12px;
        border-bottom: 1px solid var(--border);
      }
      .blocks .blk-table th {
        background: var(--bg-card);
        font-weight: 600; color: var(--text-secondary);
        font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em;
      }
      .blocks .blk-table tr:last-child td { border-bottom: none; }
      .blocks .blk-link {
        color: var(--accent); text-decoration: underline;
        text-decoration-thickness: 1px; text-underline-offset: 2px;
      }
      .blocks .blk-link:hover { text-decoration-thickness: 2px; }
      /* External links leave the wiki: mark them with a small arrow. */
      .blocks .blk-link::after {
        content: "\2197"; font-size: 0.7em;
        margin-left: 1px; vertical-align: 3px;
        opacity: 0.7;
      }
      /* Inline mention of another doc: an accent chip with a page icon,
         clearly an object reference rather than a URL. */
      .blocks .blk-doc-mention {
        color: var(--accent); font-weight: 500;
        text-decoration: none;
        background: color-mix(in srgb, var(--accent) 9%, transparent);
        border-radius: 4px; padding: 1px 4px 2px;
        white-space: nowrap;
      }
      .blocks .blk-doc-mention:hover {
        background: color-mix(in srgb, var(--accent) 18%, transparent);
      }
      .blocks .blk-doc-mention .mention-icon {
        width: 12px; height: 12px; display: inline-block;
        vertical-align: -1px; margin-right: 3px; opacity: 0.85;
      }
      .blocks .blk-inline-code {
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px;
        background: var(--bg-card);
        padding: 1.5px 5px; border-radius: 3px;
        border: 1px solid var(--border);
      }
      /* ===== Views (docs page switcher + kanban) ===== */
      .docs-head { display: flex; align-items: baseline; gap: 12px; }
      .view-modified {
        font-size: 11px; color: var(--attn);
        display: inline-flex; gap: 8px; align-items: baseline;
      }
      .view-reset {
        font: inherit; color: var(--text-muted); background: none; border: none;
        cursor: pointer; text-decoration: underline; padding: 0;
      }
      .view-reset:hover { color: var(--text); }
      /* The page title IS the view switcher: an h1-sized button with a
         quiet chevron; the menu lists every view with its description.
         Only this page gets an interactive title — it's the one page
         with sibling identities to switch between. */
      .title-fdd { position: relative; }
      .title-fdd-btn {
        font: inherit; color: inherit;
        background: none; border: none; cursor: pointer;
        display: inline-flex; align-items: center; gap: 8px;
        padding: 2px 10px 2px 8px; margin-left: -8px;
        border-radius: 8px;
      }
      .title-fdd-btn:hover { background: var(--bg-card); }
      .title-chev {
        width: 18px; height: 18px; flex: none;
        color: var(--text-muted); margin-top: 3px;
      }
      /* Two-class selector: the generic .fdd-menu rule sits later in
         this file and would win a same-specificity tie. */
      .title-fdd .title-fdd-menu {
        min-width: 560px; max-width: 640px;
        max-height: 60vh; overflow-y: auto;
      }
      .vmenu-item {
        display: flex; align-items: flex-start; gap: 10px;
        padding: 8px 10px; border-radius: 6px;
        text-decoration: none;
      }
      .vmenu-item:hover { background: rgba(255,255,255,0.04); }
      .vmenu-item .fdd-check { margin-top: 3px; }
      .vmenu-body { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
      .vmenu-name {
        font-size: 13px; font-weight: 600; color: var(--text);
        display: inline-flex; align-items: center; gap: 6px;
      }
      /* Why this view sorts first and lives in the sidebar. */
      .vmenu-pin { width: 11px; height: 11px; flex: none; color: var(--accent); }
      .vmenu-desc {
        font-size: 11.5px; color: var(--text-muted); line-height: 1.5;
        overflow: hidden; display: -webkit-box;
        -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      }
      /* Phones: a 560px anchored popover cannot fit the viewport — the
         menu becomes a fixed sheet pinned just under the title, full
         width minus a gutter. Type gets explicit sizes so nothing
         inherits the h1 scale, and descriptions drop to one line. */
      @media (max-width: 720px) {
        .title-fdd .title-fdd-menu {
          position: fixed; left: 12px; right: 12px; top: 64px;
          min-width: 0; max-width: none; width: auto;
          max-height: calc(100dvh - 88px);
        }
        .vmenu-name { font-size: 13px; }
        .vmenu-desc { font-size: 11.5px; -webkit-line-clamp: 1; }
      }
      /* Grouped list: section headers between plain card rows. */
      .group-dot {
        width: 9px; height: 9px; border-radius: 50%;
        background: var(--text-muted); flex: none;
      }
      .grouped-list { display: flex; flex-direction: column; }
      .group-block { display: flex; flex-direction: column; }
      .group-head {
        display: flex; align-items: center; gap: 8px;
        width: 100%; text-align: left;
        margin: 22px 0 10px; padding: 0 0 6px;
        background: none; border: none; border-bottom: 1px solid var(--border);
        cursor: pointer; font: inherit;
      }
      .group-block:first-child .group-head { margin-top: 4px; }
      .group-chev {
        width: 14px; height: 14px; flex: none; color: var(--text-muted);
        transition: transform 0.12s ease;
      }
      .group-collapsed .group-chev { transform: rotate(-90deg); }
      .group-head-name {
        font-size: 12px; font-weight: 600; color: var(--text-secondary);
        text-transform: uppercase; letter-spacing: 0.05em;
      }
      .group-head-count {
        font-size: 11px; color: var(--text-muted);
        background: var(--bg-card); border-radius: 999px; padding: 1px 7px;
      }
      .group-body { display: flex; flex-direction: column; }
      .subgroup { margin-left: 22px; }
      .subgroup-head {
        display: flex; align-items: center; gap: 7px;
        margin: 12px 0 6px;
      }
      .subgroup-head-name {
        font-size: 11px; font-weight: 600; color: var(--text-muted);
        letter-spacing: 0.03em;
      }
      .group-dot-sm { width: 7px; height: 7px; }

      /* Sidebar pinned views: expanded mode only. */
      .sidebar-views { display: flex; flex-direction: column; }
      .sidebar-views .sidebar-item { padding-left: 34px; font-size: 12.5px; }
      html.sidebar-collapsed .sidebar-views { display: none; }

      /* ===== Access gate (private /w/* URLs) ===== */
      .gate-body {
        display: flex; flex-direction: column; align-items: center;
        gap: 12px; text-align: center;
      }
      .gate-title { font-size: 17px; font-weight: 600; color: var(--text); }
      .gate-copy { font-size: 13.5px; color: var(--text-secondary); line-height: 1.6; }
      .gate-slug {
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px;
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: 4px; padding: 1px 6px;
      }
      /* .auth-submit assumes a <button> (native label centering); on an
         anchor the text top-aligns inside the 40px box — flex-center it. */
      a.gate-btn {
        display: flex; align-items: center; justify-content: center;
        text-decoration: none;
      }
      .gate-fine { font-size: 11.5px; color: var(--text-muted); line-height: 1.6; max-width: 320px; }

      /* ===== Data sources page ===== */
      .ds-empty {
        max-width: 520px; margin: 48px auto 0; text-align: center;
        display: flex; flex-direction: column; align-items: center; gap: 12px;
      }
      .ds-empty-icon {
        width: 44px; height: 44px; color: var(--accent);
        display: inline-flex; align-items: center; justify-content: center;
        background: color-mix(in srgb, var(--accent) 10%, transparent);
        border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
        border-radius: 12px;
      }
      .ds-empty-icon svg { width: 22px; height: 22px; }
      .ds-empty-title { font-size: 16px; font-weight: 600; color: var(--text); }
      .ds-empty-copy { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }
      .ds-empty-code { text-align: left; width: 100%; overflow-x: auto; }
      .ds-empty-fine { font-size: 11.5px; color: var(--text-muted); }
      /* Shared with the source detail page. */
      .ds-adapter {
        font-size: 10.5px; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.05em; padding: 1px 7px; border-radius: 999px;
        border: 1px solid var(--border-strong, var(--border)); color: var(--text-secondary);
      }
      .ds-builtin-badge { font-size: 10.5px; color: var(--text-muted); font-style: italic; }
      .ds-conn { font-family: 'JetBrains Mono', monospace; font-size: 11.5px; }
      .ds-count { color: var(--text-secondary); }
      .ds-doc-link { color: var(--accent); text-decoration: none; }
      .ds-doc-link:hover { text-decoration: underline; }

      /* ===== Data sources page: source cards ===== */
      .ds-grid {
        /* minmax(0,1fr), not 1fr: a bare 1fr track's min-content floor
           lets one unbreakable string (a connection URL) blow the card
           past the container and off the phone's right edge. */
        display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px;
        margin-top: 4px;
      }
      .ds-card {
        display: flex; flex-direction: column; gap: 10px;
        padding: 18px 20px 16px;
        background: var(--bg);
        border: 1px solid var(--border-strong);
        border-radius: 12px;
        text-decoration: none;
        text-align: left; font: inherit; cursor: pointer;
        transition: border-color 0.15s ease, transform 0.15s ease;
      }
      .ds-card:hover { border-color: var(--text-muted); }
      .ds-card-active { border-color: var(--accent); }
      .ds-card-active:hover { border-color: var(--accent-hover); }
      .ds-filter-on { color: var(--accent); font-weight: 500; }
      .ds-card-deleted { opacity: 0.55; }
      .ds-card-head { display: flex; align-items: center; gap: 10px; min-width: 0; }
      .ds-glyph {
        width: 32px; height: 32px; flex-shrink: 0;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 8px;
        background: rgba(255,255,255,0.05);
        color: var(--text-secondary);
      }
      .ds-glyph svg { width: 17px; height: 17px; }
      .ds-glyph-postgres  { background: rgba( 84,132,222,0.14); color: #7ea6f0; }
      .ds-glyph-mysql     { background: rgba(222,148, 66,0.14); color: #e8a45c; }
      .ds-glyph-redshift  { background: rgba(222, 84, 96,0.14); color: #ef7e8a; }
      .ds-glyph-workspace { background: rgba(158,110,240,0.14); color: #b990f5; }
      .ds-card-name {
        font-size: 15px; font-weight: 600; color: var(--text);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .ds-chip {
        font-size: 10px; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.05em; padding: 2px 8px; border-radius: 999px;
        flex-shrink: 0;
        border: 1px solid var(--border-strong); color: var(--text-secondary);
      }
      .ds-chip-postgres  { border-color: rgba( 84,132,222,0.4); color: #7ea6f0; }
      .ds-chip-mysql     { border-color: rgba(222,148, 66,0.4); color: #e8a45c; }
      .ds-chip-redshift  { border-color: rgba(222, 84, 96,0.4); color: #ef7e8a; }
      .ds-chip-workspace { border-color: rgba(158,110,240,0.4); color: #b990f5; }
      .ds-chip-quiet { border-color: var(--border); color: var(--text-muted); }
      .ds-chip-danger { border-color: rgba(229,72,77,0.4); color: var(--danger); }
      .ds-card-body {
        font-size: 12.5px; color: var(--text-muted); line-height: 1.5;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .ds-card-foot {
        display: flex; align-items: center; gap: 8px;
        font-size: 12px; color: var(--text-muted);
        margin-top: auto;
      }
      .ds-card-foot strong { color: var(--text); font-weight: 600; font-variant-numeric: tabular-nums; }
      .ds-foot-dot { opacity: 0.5; }
      .ds-foot-right {
        margin-left: auto; display: inline-flex; align-items: center; gap: 8px;
        font-size: 11.5px;
      }
      .qc-foot-by { margin-left: auto; font-size: 11.5px; }
      .ds-card-arrow { color: var(--text-muted); transition: transform 0.15s ease, color 0.15s ease; }

      /* ===== Query catalog: header + search + cards ===== */
      .qc-header {
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; margin: 36px 0 14px;
      }
      .qc-search-form { position: relative; width: 260px; }
      .qc-search-icon {
        position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
        width: 14px; height: 14px; color: var(--text-muted); pointer-events: none;
      }
      .qc-search {
        width: 100%; height: 32px;
        padding: 0 12px 0 32px;
        background: var(--bg-input, var(--bg-card));
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 12.5px; color: var(--text);
      }
      .qc-search:focus { outline: none; border-color: var(--accent-dim, var(--accent)); }
      .qc-search::placeholder { color: var(--text-muted); }
      .qc-grid {
        display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px;
      }
      .qc-card {
        display: flex; flex-direction: column; gap: 7px;
        padding: 14px 16px 12px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        text-decoration: none;
        text-align: left; font: inherit; cursor: pointer;
        width: 100%;
        transition: border-color 0.15s ease;
      }
      .qc-card:hover { border-color: var(--text-muted); }
      .qc-filter-chip {
        margin-left: 10px;
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        padding: 2px 8px; border-radius: 999px;
        background: var(--accent-dim); color: var(--accent);
        border: 1px solid rgba(59,130,246,0.35); cursor: pointer;
      }
      .qc-filter-chip:hover { border-color: var(--accent); }
      .qc-card-head { display: flex; align-items: center; gap: 10px; min-width: 0; }
      .qc-name {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px; font-weight: 600; color: var(--text);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        flex: 1;
      }
      .qc-desc {
        font-size: 12.5px; color: var(--text-secondary); line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .qc-desc-missing { color: var(--text-muted); font-style: italic; }
      .qc-foot {
        display: flex; align-items: center; gap: 8px;
        font-size: 11.5px; color: var(--text-muted);
        margin-top: auto;
      }
      .qc-foot strong { color: var(--text); font-weight: 600; font-variant-numeric: tabular-nums; }
      .qc-unused { font-style: italic; }
      .qc-none {
        padding: 28px 0; text-align: center;
        font-size: 13px; color: var(--text-muted);
      }
      /* Timeline milestones: one horizontal line, dots positioned by
         date, names above (two alternating rows so neighbors don't
         collide), full detail in a hover card. Same amber as the chart
         markers so the two read as one system. */
      .tl-strip {
        position: relative;
        height: 84px;
        margin: 2px 0 0;
        /* Tooltips near the strip's edges are laid out (opacity 0) and
           would widen the page; clip x only, tips still hang below. */
        overflow-x: clip; overflow-y: visible;
      }
      .tl-line {
        position: absolute; left: 0; right: 0; top: 58px;
        height: 1px; background: var(--border-strong);
      }
      .tl-edge {
        position: absolute; top: 66px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 10.5px; color: var(--text-muted);
      }
      .tl-edge-left { left: 0; }
      .tl-edge-right { right: 0; }
      .tl-marker {
        position: absolute; top: 58px;
        transform: translateX(-50%);
        z-index: 1;
      }
      .tl-marker:hover { z-index: 3; }
      .tl-marker-dot {
        position: absolute; top: -4.5px; left: 50%;
        transform: translateX(-50%);
        width: 9px; height: 9px; border-radius: 50%;
        background: var(--attn);
        box-shadow: 0 0 0 3px var(--bg);
        transition: transform 0.12s ease;
      }
      .tl-marker:hover .tl-marker-dot { transform: translateX(-50%) scale(1.35); }
      .tl-marker-label {
        position: absolute; bottom: 12px; left: 50%;
        transform: translateX(-50%);
        font-size: 11px; color: var(--text-secondary);
        white-space: nowrap; max-width: 150px;
        overflow: hidden; text-overflow: ellipsis;
      }
      .tl-marker-high .tl-marker-label { bottom: 30px; }
      /* faint stem connecting a raised label back to its dot */
      .tl-marker-high::before {
        content: "";
        position: absolute; bottom: 4px; left: 50%;
        width: 1px; height: 24px;
        background: var(--border-strong);
      }
      .tl-tip {
        position: absolute; top: 14px; left: 50%;
        transform: translateX(-50%);
        min-width: 190px; max-width: 280px;
        background: var(--bg-elevated);
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        padding: 10px 12px;
        box-shadow: 0 10px 24px rgba(0,0,0,0.5);
        opacity: 0; pointer-events: none;
        transition: opacity 0.1s ease;
        z-index: 5;
      }
      .tl-marker:hover .tl-tip { opacity: 1; }
      .tl-tip-name { font-size: 12.5px; font-weight: 600; color: var(--text); }
      .tl-tip-date {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10.5px; color: var(--text-muted); margin-top: 2px;
      }
      .tl-tip-desc { font-size: 12px; color: var(--text-secondary); margin-top: 6px; line-height: 1.5; }
      @media (max-width: 860px) {
        .ds-grid, .qc-grid { grid-template-columns: minmax(0, 1fr); }
        .qc-header { flex-direction: column; align-items: stretch; }
        .qc-search-form { width: 100%; }
      }

      /* SQL block shared by the query modal (formatted by the SqlFormat
         hook; hidden until formatted so the raw one-liner never flashes). */
      .q-sql {
        margin: 8px 0 0; padding: 8px 10px; border-radius: var(--radius-sm);
        background: var(--bg-input); overflow-x: auto;
        font-family: 'JetBrains Mono', monospace; font-size: 11.5px;
        color: var(--text-secondary); white-space: pre; line-height: 1.5;
      }
      .q-sql.q-sql-loading { visibility: hidden; }

      /* ===== Query modal ===== */
      /* Queries are the page's main object — the modal gets real room:
         most of the viewport on desktop, SQL soaking up the height. */
      /* .modal-card.qm-card (not just .qm-card): the base .modal-card
         rule sits later in this sheet, so its 480px max-width wins any
         equal-specificity tie. */
      .modal-card.qm-card {
        max-width: min(1200px, 94vw);
        height: min(680px, 88vh);
        display: flex; flex-direction: column;
        overflow-y: auto;
        padding: 26px 30px;
      }
      .qm-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
      .qm-name { font-size: 16px; flex: 0 1 auto; }
      .qm-close {
        margin-left: auto;
        background: none; border: none; cursor: pointer;
        color: var(--text-muted); font-size: 14px;
        padding: 4px 6px; border-radius: 5px;
      }
      .qm-close:hover { color: var(--text); background: rgba(255,255,255,0.06); }
      .qm-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.55; margin: 0 0 12px; }
      .qm-deps {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        margin-bottom: 8px; font-size: 11.5px;
      }
      .qm-deps-label {
        font-size: 10px; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--text-muted);
        min-width: 62px;
      }
      .qm-dep-chip {
        font-family: 'JetBrains Mono', monospace; font-size: 11.5px;
        padding: 2px 8px; border-radius: 5px;
        background: var(--bg-input); color: var(--text-secondary);
        border: 1px solid var(--border); cursor: pointer;
        transition: color 0.1s ease, border-color 0.1s ease;
      }
      .qm-dep-chip:hover { color: var(--text); border-color: var(--text-muted); }
      .qm-doc-link {
        font-size: 12px; color: var(--accent); text-decoration: none;
        padding: 2px 0;
      }
      .qm-doc-link:hover { text-decoration: underline; }
      .qm-sql {
        margin-top: 12px;
        flex: 1; min-height: 120px;
        overflow: auto;
        font-size: 12.5px; line-height: 1.6;
        padding: 12px 14px;
      }
      .qm-meta { margin-top: 12px; font-size: 11.5px; color: var(--text-muted); flex-shrink: 0; }

      /* chart block — Contex SVG or result table + caption. Errors are
         states on the block, styled quiet, never page-breaking. */
      .blocks .blk-chart { margin: 4px 0; }
      /* chart/sql pane switcher — tiny, right-aligned, client-only. */
      .blocks .chart-tabs {
        display: flex; justify-content: flex-end; gap: 2px;
        margin-bottom: 4px;
      }
      .blocks .chart-tab {
        font: inherit; font-size: 10.5px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.05em;
        color: var(--text-muted); background: none;
        border: none; border-radius: 4px;
        padding: 2px 7px; cursor: pointer;
      }
      .blocks .chart-tab:hover { color: var(--text-secondary); }
      .blocks .chart-tab-active {
        color: var(--text); background: rgba(255,255,255,0.06);
      }
      /* ECharts owns the inside of this div (canvas); it just needs a
         real size to draw into. */
      .blocks .chart-plot { width: 100%; height: 280px; }
      .blocks .chart-error {
        padding: 10px 14px; border: 1px dashed var(--border-strong, var(--border));
        border-radius: var(--radius); font-size: 12.5px; color: var(--text-secondary);
        font-family: 'JetBrains Mono', monospace;
      }
      /* async run states — placeholder box matches the plot's height so
         the page doesn't jump when results stream in. */
      .blocks .chart-placeholder {
        display: flex; align-items: center; justify-content: center; gap: 10px;
        height: 280px; border: 1px dashed var(--border);
        border-radius: var(--radius); font-size: 12.5px; color: var(--text-muted);
      }
      .blocks .chart-spinner {
        width: 12px; height: 12px; border-radius: 50%;
        border: 2px solid var(--border-strong, var(--border));
        border-top-color: var(--text-muted);
        animation: chart-spin 0.8s linear infinite;
      }
      @keyframes chart-spin { to { transform: rotate(360deg); } }
      .blocks .chart-run-btn {
        font: inherit; font-size: 12px; font-weight: 600;
        color: var(--text-secondary); background: var(--bg-card);
        border: 1px solid var(--border); border-radius: var(--radius);
        padding: 4px 12px; cursor: pointer;
      }
      .blocks .chart-run-btn:hover { color: var(--text); border-color: var(--border-strong); }
      .blocks .chart-idle-note { font-size: 11px; color: var(--text-muted); }
      .blocks .chart-refresh {
        font: inherit; font-size: 11px; color: var(--text-muted);
        background: none; border: none; padding: 0; cursor: pointer;
        margin-left: auto;
      }
      .blocks .chart-refresh:hover { color: var(--text-secondary); }
      .blocks .chart-caption {
        display: flex; gap: 12px; margin-top: 4px;
        font-size: 11px; color: var(--text-muted);
      }
      /* "inline" tag: this chart's SQL is anonymous, not a named query. */
      .blocks .chart-inline { font-style: italic; opacity: 0.8; }
      .blocks .blk-unknown {
        padding: 10px 14px; border: 1px dashed var(--danger);
        border-radius: var(--radius); font-size: 13px; color: var(--danger);
      }
      .blocks .doc-link-card-tags { margin-top: 8px; }
      .blocks .doc-link-card {
        display: block;
        padding: 12px 16px;
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--radius);
        text-decoration: none;
        transition: border-color 0.08s ease, background 0.08s ease;
      }
      a.doc-link-card:hover { border-color: var(--border-strong); background: var(--bg-elevated); }
      .doc-link-card-title {
        font-size: 14px; font-weight: 600; color: var(--text);
        display: flex; align-items: center; gap: 8px;
      }
      .doc-link-card-title::before {
        content: "→";
        color: var(--accent); font-weight: 500; flex: none;
      }
      .doc-link-card-summary {
        margin-top: 3px; font-size: 12.5px; line-height: 1.5;
        color: var(--text-secondary);
      }
      .doc-link-card-dead {
        border-style: dashed; opacity: 0.7;
      }
      .doc-link-card-dead .doc-link-card-title::before { content: "×"; color: var(--text-muted); }
      .blocks .doc-link-note {
        margin-top: 6px; font-size: 13px; line-height: 1.6;
        color: var(--text-secondary); font-style: italic;
      }

      /* ===== Workspace home shelves ===== */
      /* A faint accent glow at the top gives the page depth without
         breaking the mono surface system. */
      .home-content {
        position: relative;
      }
      .home-content::before {
        content: "";
        position: absolute; inset: -40px -60px auto -60px; height: 340px;
        background: radial-gradient(ellipse 70% 100% at 50% 0%,
          rgba(59,130,246,0.07), transparent 70%);
        pointer-events: none;
      }
      .home-content > * { position: relative; }
      /* Same type as every other page-title; only the bottom margin is
         set here, standing in for the page-subtitle other pages have. */
      .home-title { margin-bottom: 44px; }

      /* Lives inside the pinned story-grid as a full-width lead row. */
      .orientation-card {
        grid-column: 1 / -1;
        display: flex; align-items: center; gap: 14px;
        padding: 16px 18px;
        background: linear-gradient(135deg, rgba(59,130,246,0.16), rgba(139,92,246,0.08) 60%, rgba(59,130,246,0.04));
        border: 1px solid rgba(59,130,246,0.28);
        border-radius: 12px;
        text-decoration: none;
        transition: border-color 0.12s ease, transform 0.12s ease, box-shadow 0.12s ease;
      }
      .orientation-card:hover {
        border-color: rgba(59,130,246,0.55);
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(59,130,246,0.10);
      }
      .orientation-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
      .orientation-title { font-size: 14.5px; font-weight: 600; color: var(--text); }
      .orientation-summary { font-size: 12.5px; color: var(--text-secondary); }
      .orientation-cta {
        flex: none; margin-left: auto;
        font-size: 12.5px; font-weight: 500; color: var(--accent);
        white-space: nowrap;
      }

      .shelf { margin-top: 34px; }
      /* Whichever shelf renders first sits flush under the title. */
      .home-content .shelf:first-of-type { margin-top: 0; }
      /* Quiet footer link under a shelf's list ("View all … →"). */
      .shelf-more {
        display: inline-block; margin-top: 8px; padding: 2px 4px;
        font-size: 12px; font-weight: 500;
        color: var(--text-muted); text-decoration: none;
      }
      .shelf-more:hover { color: var(--accent); }
      .shelf-head {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 12px;
      }
      /* Rule line after each shelf head gives the page rhythm. */
      .shelf-head::after {
        content: ""; flex: 1; height: 1px;
        background: linear-gradient(90deg, var(--border), transparent);
        margin-left: 6px;
      }
      .shelf-icon {
        flex: none; width: 14px; height: 14px;
        display: inline-flex; color: var(--text-muted);
      }
      .shelf-icon svg { width: 14px; height: 14px; }
      .shelf-icon-attn { color: var(--attn); }
      .shelf-label {
        font-size: 11.5px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.09em;
        color: var(--text-secondary);
      }
      .shelf-count {
        font-size: 11px; color: var(--text-muted);
        border: 1px solid var(--border-strong); border-radius: 999px;
        padding: 0 7px; line-height: 16px;
      }
      .shelf-count-attn {
        color: var(--attn); border-color: var(--attn-border);
        background: var(--attn-dim);
      }

      /* Jump back in — the user's own recent reads, compact */
      .jump-grid {
        display: grid; gap: 10px;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
      }
      .jump-card {
        display: flex; flex-direction: column; gap: 2px;
        padding: 10px 14px;
        background: linear-gradient(180deg, rgba(255,255,255,0.025), transparent), var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        text-decoration: none;
        transition: border-color 0.12s ease, transform 0.12s ease, box-shadow 0.12s ease;
        min-width: 0;
      }
      .jump-card:hover {
        border-color: var(--border-strong);
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(0,0,0,0.35);
      }
      .jump-card-title {
        font-size: 13px; font-weight: 500; color: var(--text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .jump-card-time { font-size: 11px; color: var(--text-muted); }

      /* Start here — pinned doc cards, each with its identity hue */
      .story-grid {
        display: grid; gap: 12px;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      }
      .story-card {
        position: relative; overflow: hidden;
        display: block;
        padding: 16px 18px;
        background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent 55%), var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        text-decoration: none;
        transition: border-color 0.12s ease, transform 0.12s ease, box-shadow 0.12s ease;
      }
      .story-card:hover {
        border-color: var(--border-strong);
        transform: translateY(-2px);
        box-shadow: 0 10px 28px rgba(0,0,0,0.40);
      }
      .story-card-top { display: flex; align-items: center; gap: 10px; min-width: 0; }
      .story-card-title {
        font-size: 14px; font-weight: 600; color: var(--text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .story-card-summary {
        margin-top: 8px; font-size: 12.5px; line-height: 1.55;
        color: var(--text-secondary);
      }
      .story-card-tags { margin-top: 10px; display: flex; gap: 5px; flex-wrap: wrap; }
      .story-card-tag {
        font-size: 10.5px; color: var(--text-muted);
        border: 1px solid var(--border); border-radius: 4px;
        padding: 1px 6px;
        background: rgba(255,255,255,0.02);
      }

      /* Needs you — open-thread rows */
      .attn-list {
        border: 1px solid var(--attn-border); border-radius: 12px;
        background: linear-gradient(180deg, var(--attn-dim), transparent 30%), var(--bg-card);
        overflow: hidden;
      }
      .attn-row {
        display: flex; align-items: baseline; gap: 11px;
        padding: 11px 16px; text-decoration: none;
        border-bottom: 1px solid var(--border);
        transition: background 0.08s ease;
        min-width: 0;
      }
      .attn-row:last-child { border-bottom: none; }
      .attn-row:hover { background: rgba(255,255,255,0.025); }
      .attn-body {
        font-size: 13px; color: var(--text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .attn-meta {
        flex: none; margin-left: auto; font-size: 11.5px; color: var(--text-muted);
        white-space: nowrap;
      }
      .attn-via {
        font-size: 10.5px; color: var(--text-muted);
        border: 1px solid var(--border-strong); border-radius: 4px;
        padding: 0 4px; margin-left: 2px;
      }
      .attn-doc { color: var(--text-secondary); }

      /* Recently changed — digest rows with a timeline spine */
      .recent-list { display: flex; flex-direction: column; }
      .recent-row {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 4px; text-decoration: none;
        border-bottom: 1px solid var(--border);
        min-width: 0;
        border-radius: 6px;
        transition: background 0.08s ease;
      }
      .recent-row:last-child { border-bottom: none; }
      .recent-row:hover { background: rgba(255,255,255,0.02); }
      .recent-row:hover .recent-title { color: var(--accent); }
      .recent-title {
        flex: none; font-size: 13px; font-weight: 500; color: var(--text);
        transition: color 0.08s ease;
      }
      .recent-version {
        flex: none; font-size: 10.5px; color: var(--text-secondary);
        font-family: 'JetBrains Mono', monospace;
        border: 1px solid var(--border-strong); border-radius: 4px;
        padding: 0 5px; line-height: 15px;
        background: rgba(255,255,255,0.03);
      }
      .recent-intent {
        font-size: 12.5px; color: var(--text-secondary); font-style: italic;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .recent-time {
        flex: none; margin-left: auto; font-size: 11.5px; color: var(--text-muted);
      }


      /* Home tag glossary — the whole vocabulary as one wrapping chip
         cloud; the line below starts as a hint and becomes the clicked
         tag's description. Explains tags — does not navigate. */
      .tag-glossary {
        display: flex; flex-direction: column; gap: 10px;
      }
      .tag-cloud {
        display: flex; flex-wrap: wrap; gap: 6px;
        align-items: center;
      }
      /* Chips are buttons (click = reveal description below), not
         links — reset button chrome, keep the chip look. */
      .tag-cloud button.chip {
        font: inherit; cursor: pointer;
        border-style: solid;
      }
      .tag-cloud button.chip:hover { filter: brightness(1.25); }
      .tag-cloud .chip-open {
        outline: 1px solid var(--tag, var(--text-muted));
        outline-offset: 1px;
      }
      /* Reserve two lines so swapping hint ↔ description never shifts
         the page. */
      .tag-info {
        font-size: 12px; line-height: 1.6;
        min-height: calc(2 * 1.6em);
      }
      .tag-info-desc { color: var(--text-secondary); }
      .tag-info-hint { color: var(--text-muted); font-style: italic; }

      /* Home on phones: the card is fully tappable so the CTA label is
         redundant. */
      @media (max-width: 720px) {
        .home-title { margin-bottom: 28px; }
        .orientation-card { padding: 14px 16px; gap: 12px; }
        .orientation-cta { display: none; }
        .recent-title {
          flex: 0 1 auto;
          white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .recent-intent { display: none; }
      }

      /* Onboarding setup detection */
      .setup-status {
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; color: var(--text-secondary);
        margin: 4px 0 10px;
      }
      .setup-status-done { color: var(--text); }
      .setup-pulse {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--accent);
        animation: setup-pulse 1.6s ease-in-out infinite;
      }
      @keyframes setup-pulse {
        0%, 100% { opacity: 0.35; }
        50% { opacity: 1; }
      }
      .setup-skip {
        background: none; border: none; cursor: pointer;
        font-size: 12px; color: var(--text-muted);
        text-decoration: underline; text-underline-offset: 2px;
        padding: 0; align-self: flex-start;
      }
      .setup-skip:hover { color: var(--text-secondary); }

      /* ===== Docs filter bar (dropdowns + pills) ===== */
      /* The Docs controls (search + dropdowns + pills) read as ONE zone:
         tight 10px internal rhythm, one clear 22px break before the list.
         Control-led pages also pull the header gap in (44 → 28px) — the
         chrome isn't content, so the full content gap reads as a hole. */
      .docs-subtitle { margin-bottom: 28px; }
      .docs-controls {
        display: flex; flex-direction: column; gap: 10px;
        margin-bottom: 22px;
      }
      .docs-controls .filter-bar { margin-bottom: 0; }
      .fbar {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      }
      .fdd { position: relative; display: inline-flex; }
      .fdd-btn {
        display: inline-flex; align-items: center; gap: 6px;
        height: 30px; padding: 0 10px 0 12px;
        font-size: 12.5px; font-weight: 500; color: var(--text-secondary);
        background: var(--bg-card);
        border: 1px solid var(--border); border-radius: 7px;
        cursor: pointer;
        transition: border-color 0.08s ease, color 0.08s ease;
      }
      .fdd-btn:hover { border-color: var(--border-strong); color: var(--text); }
      .fdd-btn-active { color: var(--text); border-color: var(--accent-dim); background: var(--accent-dim); }
      .fdd-badge {
        min-width: 16px; height: 16px; padding: 0 4px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 10.5px; font-weight: 600;
        color: var(--accent);
        background: rgba(59,130,246,0.18);
        border-radius: 999px;
      }
      .fdd-chev { width: 12px; height: 12px; opacity: 0.6; }
      .fdd-menu {
        position: absolute; top: calc(100% + 6px); left: 0; z-index: 30;
        min-width: 220px; max-height: 60vh; overflow-y: auto;
        background: var(--bg-elevated);
        border: 1px solid var(--border-strong);
        border-radius: 9px;
        padding: 5px;
        box-shadow: 0 12px 28px rgba(0,0,0,0.55);
      }
      .fdd-item {
        display: flex; align-items: center; gap: 9px;
        width: 100%; text-align: left;
        padding: 6px 8px; border: none; border-radius: 6px;
        background: none; cursor: pointer;
        font-size: 13px; color: var(--text);
      }
      .fdd-item:hover { background: rgba(255,255,255,0.05); }
      .fdd-check {
        flex: none; width: 14px; height: 14px;
        border: 1px solid var(--border-strong); border-radius: 4px;
        position: relative;
      }
      .fdd-check.on { background: var(--accent); border-color: var(--accent); }
      .fdd-check.on::after {
        content: "";
        position: absolute; left: 4px; top: 1px;
        width: 4px; height: 8px;
        border: solid #fff; border-width: 0 1.5px 1.5px 0;
        transform: rotate(45deg);
      }
      .fdd-radio { border-radius: 50%; }
      .fdd-radio.on::after {
        left: 3px; top: 3px; width: 6px; height: 6px;
        border: none; border-radius: 50%; background: #fff;
        transform: none;
      }
      .fdd-item-label { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .fdd-item-count, .fdd-item-hint {
        margin-left: auto; font-size: 11px; color: var(--text-muted);
        white-space: nowrap;
      }
      .fdd-section {
        font-size: 10.5px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        padding: 8px 8px 4px;
        border-top: 1px solid var(--border);
        margin-top: 4px;
      }
      .fbar-clear {
        margin-left: auto;
        background: none; border: none; cursor: pointer;
        font-size: 12px; color: var(--text-muted);
        transition: color 0.08s ease;
      }
      .fbar-clear:hover { color: var(--danger); }

      /* ===== Board (tag-driven kanban) ===== */


      /* ===== Version switcher (dropdown next to v{n} chip) ===== */
      .version-switcher { position: relative; display: inline-flex; }
      .version-switcher > summary {
        list-style: none; cursor: pointer; user-select: none;
        display: inline-flex; align-items: center; gap: 4px;
      }
      .version-switcher > summary::-webkit-details-marker { display: none; }
      .version-switcher-trigger {
        color: var(--text-muted); font-size: 12px;
        padding: 2px 4px; border-radius: 4px;
        transition: background 0.08s ease, color 0.08s ease;
      }
      .version-switcher-trigger:hover { background: rgba(255,255,255,0.05); color: var(--text-secondary); }
      .version-switcher[open] .version-switcher-trigger {
        background: rgba(255,255,255,0.06); color: var(--text);
      }
      .version-switcher-chev {
        width: 11px; height: 11px;
        transition: transform 0.12s ease;
        opacity: 0.7;
      }
      .version-switcher[open] .version-switcher-chev { transform: rotate(180deg); }
      .version-switcher-menu {
        position: absolute;
        top: calc(100% + 6px); left: 0;
        min-width: 320px; max-width: 460px;
        background: var(--bg-elevated);
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        padding: 4px;
        box-shadow: 0 12px 28px rgba(0,0,0,0.55);
        z-index: 20;
        max-height: 70vh; overflow-y: auto;
      }
      .version-switcher-item {
        display: grid;
        grid-template-columns: auto auto 1fr auto;
        align-items: center; gap: 8px;
        padding: 7px 9px; border-radius: 5px;
        font-size: 13px; color: var(--text-secondary);
        text-decoration: none;
        line-height: 18px;
      }
      .version-switcher-item:hover { background: rgba(255,255,255,0.05); color: var(--text); }
      .version-switcher-item.current { color: var(--text); background: rgba(255,255,255,0.03); }
      .version-switcher-num {
        font-weight: 500; font-variant-numeric: tabular-nums;
        color: var(--text); min-width: 28px;
      }
      .version-switcher-actor {
        display: inline-flex; align-items: center; gap: 5px;
        color: var(--text-secondary); font-size: 12.5px;
      }
      .version-switcher-time {
        font-size: 11.5px; color: var(--text-muted); text-align: right;
        white-space: nowrap;
      }
      .version-switcher-item .check { color: var(--accent); font-size: 12px; }
      .version-switcher-intent {
        grid-column: 1 / -1;
        margin-top: 2px;
        font-size: 12px; color: var(--text-muted);
        font-style: italic;
        overflow: hidden; text-overflow: ellipsis;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      }

      /* ===== Doc state banner (historical / deleted) =====
         One unified banner at the top of any doc page. At most one variant
         renders at a time — see DocShowLive.doc_state_banner/1. */
      .doc-banner {
        margin: 0 0 18px;
        padding: 10px 14px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-left: 3px solid var(--text-muted);
        border-radius: var(--radius);
        font-size: 13px;
        color: var(--text-muted);
      }
      .doc-banner-row {
        display: flex; align-items: center; gap: 8px;
        flex-wrap: wrap;
      }
      .doc-banner-tag {
        font-weight: 500; color: var(--text);
        font-variant-numeric: tabular-nums;
      }
      .doc-banner-actor {
        display: inline-flex; align-items: center; gap: 5px;
        color: var(--text-secondary);
      }
      .doc-banner-spacer { flex: 1; }
      .doc-banner-action {
        color: var(--accent); font-size: 12.5px;
        text-decoration: none;
      }
      .doc-banner-action:hover { text-decoration: underline; }
      .doc-banner-detail {
        margin-top: 6px;
        color: var(--text-secondary);
        font-style: italic;
      }
      .doc-banner-historical { border-left-color: var(--accent); }
      .doc-banner-deleted    { border-left-color: var(--danger); }

      /* ===== Team page ===== */
      /* One quiet line of workspace totals under the subtitle — the
         merged-in Usage page's hero cards, demoted on purpose. */
      .team-totals {
        margin-top: 6px;
        font-size: 12.5px;
        color: var(--text-muted);
        font-variant-numeric: tabular-nums;
      }
      .team-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 16px;
      }
      .team-row-left { display: flex; align-items: center; gap: 12px; }
      .team-row-name { font-size: 14px; font-weight: 500; color: var(--text); display: flex; align-items: center; }
      .team-row-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
      .team-row-right { display: flex; align-items: center; gap: 16px; }
      /* Fixed-width actions slot on every row (empty on your own) so the
         stats keep one right edge; "remove" only surfaces on hover. */
      .team-row-actions { width: 56px; display: flex; justify-content: flex-end; }
      .team-row .thread-action-btn { opacity: 0; transition: opacity 0.12s ease; }
      .team-row:hover .thread-action-btn,
      .team-row .thread-action-btn:focus-visible { opacity: 1; }
      .team-avatar {
        width: 34px; height: 34px;
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 600; font-size: 13.5px;
        flex-shrink: 0;
      }
      /* Per-member activity in two labeled clusters — Built (docs +
         edits they made) and Impact (views + kudos their docs earned).
         Fixed group widths so the clusters column-align across rows. */
      .team-row-stats { display: flex; gap: 28px; }
      .team-stat-group {
        display: flex; flex-direction: column; gap: 3px;
        min-width: 138px;
      }
      .team-stat-group-label {
        font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
      }
      .team-stat-group-values {
        font-size: 13px;
        color: var(--text-muted);
        white-space: nowrap;
      }
      .team-stat strong {
        color: var(--text);
        font-weight: 600; font-size: 14px;
        font-variant-numeric: tabular-nums;
      }
      /* The workspace totals line reuses .team-stat; keep it quiet there. */
      .team-totals .team-stat strong {
        font-size: inherit;
        color: var(--text-secondary);
      }
      @media (max-width: 720px) {
        .team-row-stats { display: none; }
        /* No hover on touch — keep remove always visible there. */
        .team-row .thread-action-btn { opacity: 1; }
      }

      /* ===== Invite link block ===== */
      .invite-block {
        padding: 16px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
      }
      .invite-url-row { display: flex; gap: 10px; align-items: stretch; }
      .invite-url {
        flex: 1; min-width: 0;
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px;
        background: var(--bg);
        border: 1.5px solid var(--accent-dim);
        border-radius: var(--radius);
        padding: 9px 12px;
        color: var(--accent);
        overflow-wrap: anywhere;
        user-select: all;
      }

      /* ===== Actor badge in threads ===== */
      .actor-badge { font-size: 11px; }
      .thread-resolved { color: #4ADE80; }
      .thread-content-resolved { opacity: 0.7; }

      /* ===== Doc detail layout (single column, inline comments) =====
         Outer container shares width AND padding with `.content` so the
         doc title sits at the same height as every other page's title. */
      .doc-layout {
        max-width: 1200px;
        margin: 0 auto;
        padding: 48px 28px 80px;
        width: 100%;
      }
      .doc-article { min-width: 0; }
      /* Time-travel mode: hide every action surface that would mutate a
         historical snapshot. The anchor button still works (copying a
         link is read-only), but comment buttons, action menus, and
         composers all disappear. */
      .doc-readonly .block-comment-btn { display: none !important; }
      .doc-readonly .thread-actions { display: none !important; }
      .doc-readonly .comment-composer { display: none !important; }
      .doc-readonly .comment-edit-form { display: none !important; }
      .doc-readonly .article-kudos-btn,
      .doc-readonly .article-pin-btn { pointer-events: none; opacity: 0.5; }
      /* Hide-comments mode: drop the per-block "comment on this block"
         buttons too so the reader gets a clean canvas. Comment cards
         already aren't rendered server-side in this mode. */
      .doc-comments-hidden .block-comment-btn { display: none !important; }
      /* Comment view dropdown — lives in the article meta row beside the
         version switcher and borrows its chrome. Items are buttons (the
         switcher's are links), so neutralize button defaults. */
      .comment-view-menu { min-width: 250px; }
      .comment-view-item {
        display: flex; align-items: center;
        width: 100%;
        background: none; border: none; cursor: pointer;
        font: inherit; text-align: left;
      }
      .comment-view-word { font-weight: 500; color: var(--text); min-width: 48px; }
      .comment-view-desc { flex: 1; font-size: 11.5px; color: var(--text-muted); }
      /* Deleted-comment indicator. The body still renders normally
         (readable), but a small "deleted by X" tag in the meta row
         signals that the thread was removed by its author. No strike-
         through — kept easy to scan. */
      .thread-deleted-tag {
        display: inline-flex; align-items: center; gap: 4px;
        color: var(--text-muted);
        font-style: italic;
      }
      .thread-deleted-tag svg {
        width: 11px; height: 11px;
        opacity: 0.8;
      }
      /* Collapsed reply prompt — a quiet "Reply" link sitting at the
         bottom of the comment card. Expands into the full composer on
         click. Keeps threads compact when nobody's actively replying. */
      .comment-card-reply-prompt {
        padding: 6px 14px;
        border-top: 1px solid rgba(255,255,255,0.08);
      }
      .comment-card-reply-btn {
        font-size: 11.5px;
        color: var(--text-muted);
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
      }
      .comment-card-reply-btn:hover {
        color: var(--text-secondary);
        background: rgba(255,255,255,0.05);
      }

      /* Per-block inline comments zone — sits under each block. Flat
         layout (no left line / indent) so block comments read the same
         as doc-level comments. */
      .block-comments {
        margin: 12px 0 0;
        padding-left: 0;
        border-left: none;
      }

      /* General discussion. Notion-style: at the top of the doc body,
         no label — just the threads (if any) followed by a compact
         "Add a comment…" input that expands on focus. */

      /* ===== Tags management page ===== */
      /* Header row: title + subtitle on the left, "+ New tag" on the right.
         Aligns with the page-subtitle's existing 32px bottom margin so the
         spacing under the header still feels right. */
      .tags-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        gap: 16px;
        margin-bottom: 24px;
      }
      .tags-header .page-subtitle { margin-bottom: 0; }
      .tags-new-btn {
        flex-shrink: 0;
        background: var(--accent); color: white;
        padding: 7px 14px;
        border-radius: 6px;
        font-size: 13px; font-weight: 500;
        margin-top: 4px;
      }
      .tags-new-btn:hover { background: var(--accent-hover); }

      /* Create + edit forms — no boxes, no card surface. They live as
         inline sections separated only by hairlines from the rest of the
         page, like the list rows themselves. Full row width on edit. */
      .tag-create-card {
        display: flex; flex-direction: column; gap: 14px;
        padding: 6px 0 18px;
        margin-bottom: 8px;
      }
      .tag-edit-form {
        flex: 1;
        display: flex; flex-direction: column; gap: 14px;
      }
      .tag-create-row {
        display: flex; flex-direction: column; gap: 4px;
      }
      .tag-field-label {
        font-size: 11px; font-weight: 500;
        color: var(--text-muted);
        text-transform: uppercase; letter-spacing: 0.04em;
      }
      .tag-field-input {
        font: inherit; font-size: 13.5px;
        background: var(--bg-input);
        color: var(--text);
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        padding: 7px 10px;
        outline: none;
        width: 100%;
        transition: border-color 0.08s ease;
      }
      .tag-field-input:focus { border-color: var(--accent); }
      .tag-field-mono { font-family: 'JetBrains Mono', monospace; font-size: 13px; }
      .tag-create-error {
        font-size: 12px; color: var(--danger);
      }
      .tag-create-actions {
        display: flex; justify-content: flex-end; gap: 8px;
        margin-top: 2px;
      }
      .tag-btn-primary {
        background: var(--accent); color: white;
        padding: 7px 14px; border-radius: 6px;
        font-size: 13px; font-weight: 500;
      }
      .tag-btn-primary:hover { background: var(--accent-hover); }
      .tag-btn-primary:disabled {
        background: rgba(255,255,255,0.05); color: var(--text-muted);
        cursor: not-allowed;
      }
      .tag-btn-ghost {
        background: transparent; color: var(--text-muted);
        padding: 7px 14px; border-radius: 6px;
        font-size: 13px;
      }
      .tag-btn-ghost:hover { color: var(--text); }

      /* The list itself sits as a series of clean rows separated by a
         hairline — no card-per-row, less visual weight. */
      .tag-list {
        list-style: none; padding: 0; margin: 0;
        display: flex; flex-direction: column;
        border-top: 1px solid var(--border);
      }
      .tag-row {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 14px 0;
        border-bottom: 1px solid var(--border);
      }
      .tag-row-body { flex: 1; min-width: 0; }
      .tag-row-head {
        display: flex; align-items: center; gap: 10px;
        flex-wrap: wrap;
      }
      .tag-row-desc {
        margin: 6px 0 0;
        color: var(--text-secondary);
        font-size: 13px;
        line-height: 1.5;
      }
      .tag-row-meta {
        color: var(--text-muted); font-size: 12px;
        display: inline-flex; align-items: center; gap: 8px;
      }
      .tag-row-actions {
        display: inline-flex; align-items: center; gap: 4px;
        flex-shrink: 0;
      }
      .tag-row-action {
        font-size: 12px; color: var(--text-muted);
        padding: 4px 10px; border-radius: 5px;
        background: transparent;
      }
      .tag-row-action:hover { color: var(--text); background: rgba(255,255,255,0.04); }
      .tag-row-action-danger:hover { color: var(--danger); background: rgba(229,72,77,0.08); }
      .tag-row-chip { text-decoration: none; }

      /* ===== Modal (used by tag delete confirm — generic enough to reuse) ===== */
      .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.6);
        z-index: 100;
        display: flex; align-items: center; justify-content: center;
        padding: 24px;
        animation: modal-fade 0.12s ease-out;
      }
      @keyframes modal-fade {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      .modal-card {
        background: var(--bg-card);
        border: 1px solid var(--border-strong);
        border-radius: 10px;
        padding: 24px;
        width: 100%; max-width: 480px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.45);
      }
      .modal-title {
        font-size: 17px; font-weight: 600;
        color: var(--text);
        margin: 0 0 12px;
      }
      .modal-body {
        color: var(--text-secondary);
        font-size: 13.5px; line-height: 1.55;
        margin: 0 0 20px;
      }
      .modal-body strong { color: var(--text); font-weight: 600; }
      .modal-actions {
        display: flex; justify-content: flex-end; gap: 8px;
      }
      .modal-btn-danger {
        background: var(--danger); color: white;
        padding: 7px 14px; border-radius: 6px;
        font-size: 13px; font-weight: 500;
      }
      .modal-btn-danger:hover { background: #C7373B; }
      .modal-btn-danger:disabled {
        background: rgba(229,72,77,0.18);
        color: rgba(255,255,255,0.5);
        cursor: not-allowed;
      }

      /* ===== History timeline ===== */
      .event-list {
        list-style: none; padding: 0; margin: 0;
        display: flex; flex-direction: column;
      }
      .event-row {
        display: flex; align-items: center; gap: 6px;
        padding: 8px 0;
        border-bottom: 1px solid var(--border);
        font-size: 13px; color: var(--text-secondary);
        flex-wrap: wrap;
      }
      .event-row:last-child { border-bottom: none; }
      .event-actor { display: inline-flex; align-items: center; gap: 5px; }
      .event-actor-name { color: var(--text); font-weight: 500; }
      .event-via {
        font-size: 11.5px; color: var(--text-muted);
        font-style: italic;
      }
      .event-verb { color: var(--text-muted); }
      .event-target {
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
      }
      .event-target:hover { text-decoration: underline; }
      .event-detail { color: var(--text-muted); font-style: italic; }
      .event-time { color: var(--text-muted); font-size: 12px; }

      /* "Load more" button used at the bottom of paginated lists. */
      .load-more-wrap {
        display: flex; justify-content: center;
        padding: 20px 0;
      }
      .load-more-btn {
        font-size: 13px; font-weight: 500;
        color: var(--text-secondary);
        background: var(--bg-card);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        padding: 8px 18px;
        cursor: pointer;
        transition: background 0.08s ease, color 0.08s ease;
      }
      .load-more-btn:hover {
        background: var(--bg-card-hover);
        color: var(--text);
      }

      /* The TOP discussion sits flush against the article header — the
         `.doc-discussion` defaults (56px top margin, 24px top padding)
         are meant for the BOTTOM placement. Compound selector to win
         source-order over the base rule below. */
      .doc-discussion.doc-discussion-top {
        margin: 0 0 4px;
        padding-top: 14px;
      }
      .doc-discussion.doc-discussion-top:not(:has(.comment-card)) {
        margin-bottom: 0;
      }
      /* First child sits flush against the header — no extra margin-top
         on the composer when the discussion is open right under the title. */
      .doc-discussion-top > .comment-composer:first-child { margin-top: 0; }
      .doc-discussion { margin-top: 56px; padding-top: 24px; }
      .doc-discussion-header {
        display: flex; align-items: center; gap: 8px;
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 10px;
      }
      .doc-discussion-header .count {
        color: var(--text-muted); font-weight: 400;
        background: var(--bg-card); padding: 1px 6px; border-radius: 999px;
        font-size: 10px; text-transform: none; letter-spacing: 0;
      }
      .doc-discussion-subheader {
        display: flex; align-items: center; gap: 8px;
        margin: 24px 0 12px;
        padding-top: 12px;
        border-top: 1px dashed var(--border);
        font-size: 11.5px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--text-muted);
      }
      .doc-discussion-subheader .count {
        color: var(--text-muted); font-weight: 400;
        background: var(--bg-card); padding: 1px 6px; border-radius: 999px;
        font-size: 10px; text-transform: none; letter-spacing: 0;
      }
      .doc-discussion-subnote {
        text-transform: none; letter-spacing: 0;
        font-size: 11px; font-style: italic;
        margin-left: 4px;
      }
      .comment-card-wrap-orphan { padding-left: 0; }
      .orphan-snippet {
        font-size: 11px;
        color: var(--text-muted);
        padding: 4px 0 6px;
        display: flex; align-items: center; gap: 6px;
      }
      .orphan-snippet-label {
        text-transform: uppercase; letter-spacing: 0.06em;
        font-weight: 500;
      }
      .orphan-snippet-text {
        font-style: italic;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        min-width: 0;
      }

      .live-dot {
        display: inline-block;
        width: 6px; height: 6px; border-radius: 50%;
        background: #4ADE80;
        box-shadow: 0 0 8px rgba(74,222,128,0.6);
        animation: live-pulse 2s ease-in-out infinite;
        margin-left: 4px;
      }
      @keyframes live-pulse {
        0%, 100% { opacity: 0.6; transform: scale(1); }
        50%      { opacity: 1;   transform: scale(1.2); }
      }

      /* ===== Comment cards (one per thread, inline or in discussion) ===== */
      /* `ol` selector beats `.prose ol`'s 22px padding-left (specificity
         tie + source order) so block-comments lists sit flush. */
      ol.comment-card-list {
        list-style: none; padding: 0; margin: 0;
        display: flex; flex-direction: column; gap: 10px;
      }
      .comment-card-wrap { padding: 0; }
      /* One smooth shell — parent comment + replies + composer all live
         inside the same rounded card with hairline dividers between
         sections instead of nested boxes. Sections manage their own
         padding; the card just clips the corners. */
      .comment-card {
        /* Significantly lighter "raised paper" surface so comments
           clearly pop off the doc body. Reads as a distinct discussion
           surface, not another card in the dark stack. */
        background: var(--bg-card);
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 10px;
        padding: 0;
        overflow: hidden;
      }
      /* Resolved thread: keep the same surface (no dim wash, no
         transparent flip) — just a slightly subtler border so the
         "resolved" tag in the meta carries the cue. */
      .comment-card-wrap-resolved .comment-card {
        border-color: rgba(255,255,255,0.08);
      }
      /* The parent comment row gets explicit padding now that the card
         itself has none. */
      .comment-card > .thread-body { padding: 12px 14px; }
      /* Replies = continuation rows with hairlines. No inner indent / no
         nested box — they read as part of the same shell. */
      /* `ol` selector to beat `.prose ol`'s 22px padding-left when the
         thread lives inside a block-level comment zone (inside .prose). */
      ol.comment-card-replies {
        list-style: none;
        margin: 0;
        padding: 0;
        display: block;
      }
      .comment-card-replies > li {
        padding: 12px 14px;
        border-top: 1px solid rgba(255,255,255,0.08);
      }
      /* Collapsed-middle marker on a resolved thread: a thin row with a
         centered "Show N hidden replies" toggle. Sits between the original
         question and the resolving reply. */
      .comment-card-collapsed {
        padding: 6px 14px !important;
        display: flex; justify-content: center;
      }
      .comment-card-expand-btn {
        font-size: 11px;
        color: var(--text-muted);
        background: transparent;
        padding: 3px 8px;
        border-radius: 4px;
      }
      .comment-card-expand-btn:hover {
        color: var(--text-secondary);
        background: rgba(255,255,255,0.05);
      }

      .thread-body { min-width: 0; }
      .thread-meta {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        font-size: 11.5px; color: var(--text-muted);
        margin-bottom: 4px;
      }
      .thread-meta .actor-icon {
        vertical-align: 0;
        margin-right: 2px;
      }
      .thread-author { color: var(--text); font-weight: 500; font-size: 13px; }
      .thread-edited, .thread-via { font-style: italic; }
      .thread-actions { margin-left: auto; }
      .thread-action-btn {
        font-size: 11px; color: var(--text-muted);
        padding: 2px 6px; border-radius: 4px;
      }
      .thread-action-btn:hover { color: var(--text); background: rgba(255,255,255,0.05); }
      .thread-action-btn[phx-click="delete_message"]:hover { color: var(--danger); background: rgba(229,72,77,0.08); }
      .thread-actions { display: flex; gap: 4px; }

      /* No strikethrough on resolved comments — the meta tag is enough. */
      .thread-version-badge {
        font-size: 10.5px;
        padding: 1px 6px; border-radius: 3px;
        background: rgba(255,255,255,0.04);
        color: var(--text-muted);
        text-decoration: none;
        font-variant-numeric: tabular-nums;
      }
      .thread-version-badge:hover {
        background: rgba(255,255,255,0.08); color: var(--text-secondary);
      }
      .thread-content {
        color: var(--text); font-size: 13.5px; line-height: 1.55;
        word-wrap: break-word; overflow-wrap: break-word;
      }
      .thread-content > * + * { margin-top: 6px; }
      .thread-content code {
        font-family: 'JetBrains Mono', monospace; font-size: 12px;
        background: var(--bg); padding: 1px 4px; border-radius: 3px;
        border: 1px solid var(--border-strong);
      }
      .thread-content pre {
        background: var(--bg); border: 1px solid var(--border-strong);
        border-radius: 4px; padding: 10px; overflow-x: auto;
        font-size: 12px;
      }
      .thread-content p { margin: 0; }
      .thread-content a { color: var(--accent); }

      /* ===== Comment composer (block / reply / doc-level — same shell) ===== */
      .comment-composer {
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        background: var(--bg-input);
        padding: 10px 12px;
        transition: border-color 0.08s ease;
        margin-top: 10px;
      }
      .comment-composer:focus-within { border-color: var(--accent); }
      /* Block-level "Add a comment" composer — match the comment-card
         surface so a new thread reads as a member of the same family
         the moment you start typing. */
      .comment-composer-inline {
        background: var(--bg-card);
        border-color: rgba(255,255,255,0.14);
        border-radius: 10px;
      }
      .comment-composer-inline:focus-within { border-color: rgba(255,255,255,0.22); }
      .comment-composer-reply {
        margin-top: 10px;
        background: var(--bg-card);
      }
      /* Reply composer living inside a comment-card: drop the nested box
         look (own border / radius / margin) so it reads as the card's
         bottom "input" section, separated only by a hairline. */
      .comment-card > .comment-composer-reply {
        margin: 0;
        border: none;
        border-top: 1px solid rgba(255,255,255,0.08);
        border-radius: 0;
        background: rgba(0,0,0,0.18);
        padding: 10px 14px;
      }
      .comment-card > .comment-composer-reply:focus-within {
        background: rgba(0,0,0,0.28);
      }
      .comment-composer-input {
        width: 100%; border: none; outline: none;
        background: transparent; color: var(--text);
        font: inherit; font-size: 13.5px; line-height: 1.5;
        resize: none; min-height: 44px;
      }
      .comment-composer-input::placeholder { color: var(--text-muted); }
      .comment-composer-footer {
        display: flex; align-items: center; gap: 8px;
        margin-top: 6px;
      }
      .comment-composer-hint {
        font-size: 11px; color: var(--text-muted);
        margin-right: auto;
      }
      .comment-composer-cancel {
        font-size: 11px; color: var(--text-muted);
        padding: 5px 10px; border-radius: 5px;
        background: transparent;
      }
      .comment-composer-cancel:hover {
        color: var(--text); background: rgba(255,255,255,0.05);
      }
      .comment-composer-submit {
        background: var(--accent); color: white;
        padding: 5px 12px; border-radius: 5px;
        font-size: 12px; font-weight: 500;
      }
      .comment-composer-submit:hover { background: var(--accent-hover); }
      .comment-composer-submit:disabled {
        background: rgba(255,255,255,0.05); color: var(--text-muted);
        cursor: not-allowed;
      }
      /* Secondary action: visually subdued — same shape but ghost-styled
         so the primary "Reply" stays the obvious default. */
      .comment-composer-submit-resolve {
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--border-strong);
      }
      .comment-composer-submit-resolve:hover {
        background: rgba(255,255,255,0.05);
        color: var(--text);
      }

      /* Doc-level composer opens via the title's comment button — same
         inline composer shell as block-level comments, no special-case
         shrink-on-blur treatment. */

      /* ===== Auth (signup / login / show token) =====
         Mirrors the landing page's split-screen frame so the transition
         from landing → signup feels seamless. Warm parchment left,
         deep dark with vignette right, signup card floating centered on
         the seam. Card is wider here than the doc-page modals so the
         API key fits without clipping. */
      .auth-shell {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex; align-items: center; justify-content: center;
        padding: 24px;
        background: var(--bg);
        overflow: hidden;
      }
      /* Real div panes (not pseudo-elements) so each can host its own
         animated <canvas>. Hooks `OrganicCanvas` / `MatrixCanvas` in
         app.js drive the animations and respect prefers-reduced-motion. */
      .auth-pane {
        position: absolute; top: 0; bottom: 0;
        width: 50%; z-index: 0;
        overflow: hidden;
      }
      .auth-pane-human {
        left: 0;
        background: #efe8d6;
      }
      .auth-pane-human::before {
        /* Paper grain — sits over the canvas with multiply blend. */
        content: "";
        position: absolute; inset: 0;
        z-index: 1;
        pointer-events: none;
        opacity: 0.06;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        mix-blend-mode: multiply;
      }
      .auth-pane-agent {
        right: 0;
        background: #08080a;
      }
      .auth-pane-agent::after {
        /* Radial vignette over the matrix cascade — softens the edges
           so the card sits cleanly on top. */
        content: "";
        position: absolute; inset: 0;
        z-index: 1;
        pointer-events: none;
        background: radial-gradient(
          ellipse at center,
          rgba(8, 8, 10, 0.55) 0%,
          rgba(8, 8, 10, 0.8) 55%,
          rgba(8, 8, 10, 0.95) 100%
        );
      }
      .canvas-organic,
      .canvas-matrix {
        position: absolute; inset: 0;
        z-index: 0;
        display: block;
      }
      .auth-card {
        position: relative;
        z-index: 1;
        width: 100%; max-width: 460px;
        background: var(--bg-card);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-lg);
        padding: 36px 32px;
        box-shadow:
          0 20px 60px rgba(0, 0, 0, 0.55),
          0 4px 12px rgba(0, 0, 0, 0.3);
      }
      .auth-card-wide { max-width: 560px; }
      .auth-card-spare { padding: 40px 32px; }
      /* Single-pane fallback on narrow screens — drop the split. */
      @media (max-width: 720px) {
        .auth-pane { display: none; }
        .auth-shell { background: #08080a; }
      }
      .auth-brand-hero {
        justify-content: center;
        gap: 12px;
        margin-bottom: 36px;
      }
      .auth-input-hero {
        font-size: 18px;
        height: 56px;
        font-weight: 500;
        letter-spacing: -0.005em;
      }
      .auth-input-hero::placeholder {
        font-weight: 400;
      }
      .auth-brand {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 28px;
      }
      .auth-brand-name {
        font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
        font-weight: 500; font-size: 18px; letter-spacing: -0.01em;
      }
      .auth-title {
        font-size: 22px; font-weight: 600; letter-spacing: -0.015em;
        margin-bottom: 6px;
      }
      .auth-subtitle {
        color: var(--text-muted); font-size: 14px; line-height: 1.55;
        margin-bottom: 22px;
      }
      .auth-subtitle strong { color: var(--text); font-weight: 600; }
      .auth-form { display: flex; flex-direction: column; gap: 0; }
      .auth-label {
        font-size: 12px; font-weight: 500;
        color: var(--text-secondary);
        margin-bottom: 6px;
      }
      .auth-input {
        height: 40px; padding: 0 12px;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        font-size: 14px; color: var(--text);
        outline: none;
        transition: border-color 0.08s ease;
      }
      .auth-input:focus { border-color: var(--accent); }
      .auth-input-error { border-color: var(--danger); }
      .auth-hint {
        font-size: 11.5px; color: var(--text-muted);
        margin-top: 6px;
      }
      .auth-hint code {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
      }
      .auth-error {
        font-size: 12.5px; color: var(--danger);
        margin-top: 8px;
      }
      .auth-submit {
        margin-top: 18px;
        height: 40px;
        width: 100%;
        background: var(--accent); color: white;
        border-radius: var(--radius);
        font-size: 14px; font-weight: 500;
      }
      .auth-submit:hover { background: var(--accent-hover); }
      .auth-submit:disabled {
        background: rgba(255,255,255,0.06); color: var(--text-muted);
        cursor: not-allowed;
      }
      .auth-secondary {
        height: 40px; padding: 0 16px;
        background: transparent;
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        font-size: 13px; font-weight: 500;
        color: var(--text);
        transition: background 0.08s ease, color 0.08s ease;
      }
      .auth-secondary:hover { background: rgba(255,255,255,0.04); }
      .auth-secondary.copied {
        background: rgba(74,222,128,0.10);
        border-color: rgba(74,222,128,0.4);
        color: #4ADE80;
      }
      .auth-footer {
        margin-top: 24px;
        text-align: center;
        font-size: 13px;
        color: var(--text-muted);
      }
      .auth-link { color: var(--accent); }
      .auth-link:hover { text-decoration: underline; }

      .token-preview {
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px;
        background: var(--bg-input);
        border: 1px dashed var(--border-strong);
        border-radius: var(--radius);
        padding: 11px 14px;
        color: var(--text-muted);
        letter-spacing: 0.02em;
        user-select: none;
        overflow-wrap: break-word;
        word-break: break-all;
      }

      /* ===== Token field with attached copy button (show-token state) ===== */
      .token-field {
        display: flex;
        align-items: stretch;
        background: var(--bg-input);
        border: 1.5px solid var(--accent-dim);
        border-radius: var(--radius);
        overflow: hidden;
      }
      .token-field-input {
        flex: 1; min-width: 0;
        width: 100%;
        background: transparent;
        border: none; outline: none;
        padding: 12px 14px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        color: var(--accent);
        letter-spacing: 0.01em;
        /* Token is long; allow the input to scroll horizontally inside
           the field so the user can see every character on demand
           without breaking the card width. */
        overflow-x: auto;
        text-overflow: clip;
      }
      .token-field-input::selection { background: var(--accent-dim); }
      .token-field-copy {
        display: flex; align-items: center; gap: 6px;
        padding: 0 14px;
        background: rgba(255,255,255,0.04);
        border: none;
        border-left: 1.5px solid var(--accent-dim);
        color: var(--text-secondary);
        font-size: 13px; font-weight: 500;
        cursor: pointer;
        transition: background 0.08s ease, color 0.08s ease;
      }
      .token-field-copy:hover { background: rgba(255,255,255,0.07); color: var(--text); }
      .token-field-copy svg { width: 16px; height: 16px; }
      .token-field-copy.copied { color: #4ADE80; }
      .token-field-copy.copied svg { display: none; }

      /* ===== Onboarding step (post-signup) ===== */
      .onboarding-step {
        display: flex; gap: 14px;
        margin: 20px 0 24px;
      }
      .onboarding-step-num {
        width: 28px; height: 28px;
        border-radius: 50%;
        background: var(--accent-dim);
        color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 600;
        flex-shrink: 0;
      }
      .onboarding-step-body { flex: 1; min-width: 0; }
      .onboarding-step-title {
        font-size: 15px; font-weight: 600; color: var(--text);
        margin-bottom: 4px;
      }
      .onboarding-step-desc {
        font-size: 13px; color: var(--text-secondary); line-height: 1.55;
        margin-bottom: 12px;
      }
      .onboarding-step-desc code {
        font-family: 'JetBrains Mono', monospace; font-size: 12px;
        background: var(--bg-card);
        padding: 1px 5px; border-radius: 3px;
        border: 1px solid var(--border);
      }

      /* ===== Multi-line snippet with corner copy button ===== */
      .snippet {
        position: relative;
        background: var(--bg-input);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        padding: 14px 16px;
      }
      .snippet pre {
        margin: 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12.5px;
        line-height: 1.6;
        color: var(--text);
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        padding-right: 80px;
      }
      .snippet-copy {
        position: absolute;
        top: 8px; right: 8px;
        display: flex; align-items: center; gap: 5px;
        height: 26px; padding: 0 10px;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border-strong);
        border-radius: 4px;
        color: var(--text-secondary);
        font-size: 11.5px; font-weight: 500;
        cursor: pointer;
        transition: background 0.08s ease, color 0.08s ease;
      }
      .snippet-copy:hover { background: rgba(255,255,255,0.08); color: var(--text); }
      .snippet-copy svg { width: 13px; height: 13px; }
      .snippet-copy.copied { color: #4ADE80; }
      .snippet-copy.copied svg { display: none; }

      .token-display {
        background: var(--bg);
        border: 1.5px solid var(--accent-dim);
        border-radius: var(--radius);
        padding: 14px 16px;
        margin-bottom: 14px;
        overflow-wrap: break-word; word-break: break-all;
        user-select: all;
      }
      .token-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px; color: var(--accent);
        letter-spacing: 0.01em;
      }
      .auth-actions {
        display: flex; gap: 10px; align-items: stretch;
        margin-top: 4px;
      }
      .auth-actions form { flex: 1; display: flex; }
      .auth-actions .auth-submit { width: 100%; margin-top: 0; }
      .auth-divider {
        height: 1px; background: var(--border);
        margin: 24px -4px;
      }
      .auth-cli-hint-title {
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 8px;
      }
      .auth-cli-block {
        background: var(--bg); border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 10px 12px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-secondary);
      }

      /* ===== Empty state ===== */
      .empty {
        text-align: center; padding: 48px 24px;
        color: var(--text-muted); font-size: 13px;
        border: 1px dashed var(--border); border-radius: var(--radius);
      }

      /* ===== Banner ===== */
      .banner {
        padding: 12px 16px; border-radius: var(--radius);
        background: var(--bg-card); border: 1px solid var(--border);
        font-size: 13px; color: var(--text-secondary);
        margin-bottom: 16px;
      }
      .banner code {
        font-family: 'JetBrains Mono', monospace; font-size: 12px;
        background: var(--bg); padding: 1px 5px; border-radius: 3px;
        border: 1px solid var(--border-strong);
      }
      .banner-warning { border-color: rgba(242,201,76,0.30); }

      /* ===== Flash ===== */
      .flash-fixed {
        position: fixed; bottom: 16px; right: 16px; z-index: 50;
        padding: 10px 14px; border-radius: var(--radius);
        background: var(--bg-card); border: 1px solid var(--border-strong);
        font-size: 13px; color: var(--text);
        box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      }
      .flash-error { border-color: var(--danger); color: var(--danger); }

      /* ===== Phone foundation =====
         Last in the sheet on purpose: these override same-specificity
         base rules above. `overflow-x: clip` (not hidden — hidden would
         create a scroll container and break the sticky sidebar) so no
         stray wide element can drag the whole page sideways. */
      @media (max-width: 720px) {
        /* hidden first as the fallback where clip is unsupported. */
        body { overflow-x: hidden; overflow-x: clip; }
        /* The home glow pseudo reaches 60px past both edges; on phones
           that widens the page, so pin it to the container. */
        .home-content::before { left: 0; right: 0; }
        .content { padding: 28px 16px 64px; }
        .doc-layout { padding: 28px 16px 64px; }
        h1.page-title { font-size: 22px; }
        .article-title { font-size: 22px; }
        .title-chev { width: 15px; height: 15px; margin-top: 2px; }
      }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
