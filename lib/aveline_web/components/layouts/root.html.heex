<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Aveline">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
    <style>
      :root {
        --bg: #08090A;
        --bg-elevated: #101114;
        --bg-card: #131418;
        --bg-card-hover: #1A1B20;
        --bg-input: #0F1014;
        --border: rgba(255,255,255,0.06);
        --border-strong: rgba(255,255,255,0.10);
        --text: #E6E6E6;
        --text-secondary: #B4B8C0;
        --text-muted: #6E727A;
        --accent: #8B85FF;
        --accent-dim: rgba(139,133,255,0.15);
        --pinned: #F2C94C;
        --pinned-dim: rgba(242,201,76,0.12);
        --danger: #E5484D;
        --radius-sm: 4px;
        --radius: 6px;
        --radius-lg: 8px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 14px;
        line-height: 1.5;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-feature-settings: "cv11", "ss01";
      }
      code, pre, .mono {
        font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
      a { color: inherit; text-decoration: none; }
      input, textarea { font: inherit; color: inherit; }

      /* ===== App shell ===== */
      .shell { display: flex; flex-direction: column; min-height: 100vh; }
      .shell-sidebar { display: flex; flex-direction: row; min-height: 100vh; }

      /* ===== Sidebar ===== */
      .sidebar {
        width: 232px; flex-shrink: 0;
        background: var(--bg-elevated);
        border-right: 1px solid var(--border);
        display: flex; flex-direction: column;
        padding: 8px;
        height: 100vh;
        position: sticky; top: 0;
        overflow-y: auto;
      }
      .sidebar-header {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 8px 10px;
        margin-bottom: 4px;
      }
      .sidebar-workspace {
        flex: 1; min-width: 0;
        font-weight: 500; font-size: 13px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .sidebar-section { margin-bottom: 4px; }
      .sidebar-label {
        font-size: 10.5px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--text-muted);
        padding: 12px 8px 4px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .sidebar-item {
        display: flex; align-items: center; gap: 8px;
        padding: 5px 8px; border-radius: 5px;
        font-size: 13px; font-weight: 400; color: var(--text-secondary);
        margin: 1px 0;
        line-height: 18px;
      }
      .sidebar-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
      .sidebar-item.active {
        background: rgba(255,255,255,0.07);
        color: var(--text); font-weight: 500;
      }
      .sidebar-item .icon {
        width: 14px; height: 14px;
        opacity: 0.7; flex-shrink: 0;
        color: var(--text-muted);
      }
      .sidebar-item:hover .icon, .sidebar-item.active .icon {
        color: var(--text-secondary); opacity: 1;
      }
      .sidebar-item.active .icon { color: var(--accent); }
      .sidebar-item .label {
        flex: 1; min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .sidebar-item .count {
        font-size: 11px; color: var(--text-muted);
        font-variant-numeric: tabular-nums;
      }
      .sidebar-item .pin-dot {
        width: 5px; height: 5px; border-radius: 50%;
        background: var(--accent); flex-shrink: 0;
      }
      .sidebar-spacer { flex: 1; }
      .sidebar-footer {
        padding: 8px;
        border-top: 1px solid var(--border);
        margin: 8px -8px 0;
      }
      .sidebar-user {
        display: flex; align-items: center; gap: 8px;
        padding: 4px;
      }
      .sidebar-user .name {
        flex: 1; font-size: 13px; color: var(--text);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .sidebar-user a {
        font-size: 12px; color: var(--text-muted);
      }
      .sidebar-user a:hover { color: var(--text); }

      /* ===== Main area (with sidebar) ===== */
      .main-wrap {
        flex: 1; min-width: 0;
        display: flex; flex-direction: column;
      }
      .topbar {
        height: 48px; padding: 0 28px;
        display: flex; align-items: center; gap: 12px;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        position: sticky; top: 0; z-index: 10;
      }
      .topbar-title {
        font-size: 14px; font-weight: 500;
        display: flex; align-items: center; gap: 8px;
      }
      .topbar-title .star {
        color: var(--text-muted); cursor: pointer;
        width: 14px; height: 14px;
      }
      .topbar-title .star:hover { color: var(--pinned); }
      .topbar-spacer { flex: 1; }
      .topbar-meta {
        font-size: 12px; color: var(--text-muted);
        display: flex; align-items: center; gap: 8px;
      }
      .content {
        padding: 24px 28px 80px;
        flex: 1;
      }
      .content-narrow {
        padding: 32px 28px 80px;
        max-width: 760px; margin: 0 auto;
        flex: 1;
      }

      .nav {
        position: sticky; top: 0; z-index: 10;
        display: flex; align-items: center; gap: 12px;
        height: 48px; padding: 0 20px;
        background: rgba(8,9,10,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-brand {
        display: flex; align-items: center; gap: 8px;
        font-weight: 600; font-size: 14px; letter-spacing: -0.01em;
      }
      .nav-brand-mark {
        width: 18px; height: 18px; border-radius: 5px;
        background: linear-gradient(135deg, var(--accent) 0%, #5E59C6 100%);
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; color: white;
      }
      .nav-sep { color: var(--text-muted); font-size: 12px; }
      .nav-crumb {
        color: var(--text-secondary); font-weight: 500;
        max-width: 240px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .nav-crumb:hover { color: var(--text); }
      .nav-crumb-current {
        color: var(--text); font-weight: 500;
        max-width: 320px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .nav-spacer { flex: 1; }
      .nav-user { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text-secondary); }
      .nav-user .avatar {
        width: 22px; height: 22px; border-radius: 50%;
        background: var(--accent-dim); color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 600;
      }
      .nav-user a { color: var(--text-muted); }
      .nav-user a:hover { color: var(--text); }

      /* ===== Page layout ===== */
      main { flex: 1; width: 100%; }
      .container { max-width: 880px; margin: 0 auto; padding: 32px 24px 80px; }
      .container-narrow { max-width: 720px; margin: 0 auto; padding: 32px 24px 80px; }

      /* ===== Headers ===== */
      .page-eyebrow {
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 8px;
      }
      h1.page-title {
        font-size: 28px; font-weight: 600; letter-spacing: -0.02em;
        margin-bottom: 8px;
      }
      .page-subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 32px; }

      /* ===== Section labels ===== */
      .section-label {
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        margin: 24px 0 12px;
        display: flex; align-items: center; gap: 8px;
      }
      .section-label .count {
        color: var(--text-muted); font-weight: 400;
        background: var(--bg-card); padding: 1px 6px; border-radius: 999px;
        font-size: 10px;
      }

      /* ===== Cards ===== */
      .card-list { display: flex; flex-direction: column; gap: 4px; list-style: none; }
      .card {
        display: block; padding: 12px 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--bg-card);
        transition: background 0.08s ease, border-color 0.08s ease;
        position: relative;
      }
      .card:hover { background: var(--bg-card-hover); border-color: var(--border-strong); }
      .card-title {
        font-weight: 500; font-size: 14px; color: var(--text);
        display: flex; align-items: center; gap: 8px;
      }
      .card-summary {
        font-size: 13px; color: var(--text-secondary);
        margin-top: 4px;
        overflow: hidden; text-overflow: ellipsis;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      }
      .card-meta {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-top: 10px; font-size: 12px; color: var(--text-muted);
      }
      .card-slug { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-muted); }
      .card-meta-dot { color: var(--text-muted); opacity: 0.5; }

      /* ===== Avatar ===== */
      .avatar-sm {
        display: inline-flex; align-items: center; justify-content: center;
        width: 18px; height: 18px; border-radius: 50%;
        font-size: 10px; font-weight: 600;
        color: var(--text); flex-shrink: 0;
      }
      .owner-chip {
        display: inline-flex; align-items: center; gap: 6px;
        color: var(--text-secondary); font-size: 12px;
      }

      /* ===== Filter status ===== */
      .filter-status {
        display: flex; align-items: center; gap: 12px;
        font-size: 12px; color: var(--text-muted);
        margin-bottom: 12px;
      }
      .filter-status .clear {
        color: var(--accent); cursor: pointer;
        text-decoration: underline; text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }
      .filter-status .clear:hover { color: var(--text); }

      /* ===== Tooltip (browser-native via title attr) — no extra CSS ===== */

      .pin {
        display: inline-flex; align-items: center; justify-content: center;
        width: 14px; height: 14px;
        color: var(--pinned);
      }

      /* ===== Chips ===== */
      .chip {
        display: inline-flex; align-items: center;
        height: 22px; padding: 0 8px;
        border-radius: 4px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        font-size: 11.5px; color: var(--text-secondary);
        font-family: 'JetBrains Mono', monospace; font-weight: 500;
        letter-spacing: 0.01em;
      }
      .chip:hover { color: var(--text); border-color: var(--border-strong); }
      .chip-accent {
        background: var(--accent-dim);
        border-color: rgba(139,133,255,0.25);
        color: var(--accent);
      }
      .chip-active {
        background: var(--text); color: var(--bg);
        border-color: var(--text);
      }
      .chip-row { display: flex; flex-wrap: wrap; gap: 6px; }

      /* ===== Tabs ===== */
      .tabs {
        display: flex; gap: 4px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 24px;
      }
      .tab {
        padding: 8px 12px; font-size: 13px; font-weight: 500;
        color: var(--text-muted);
        border-bottom: 1.5px solid transparent;
        margin-bottom: -1px;
      }
      .tab:hover { color: var(--text-secondary); }
      .tab-active { color: var(--text); border-bottom-color: var(--accent); }
      .tab .count {
        margin-left: 6px; font-size: 11px;
        color: var(--text-muted); font-weight: 400;
      }

      /* ===== Filter bar ===== */
      .filter-bar {
        display: flex; flex-direction: column; gap: 10px;
        margin-bottom: 16px;
      }
      .search-input {
        width: 100%;
        height: 36px; padding: 0 12px;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        font-size: 13px;
        color: var(--text);
        outline: none;
        transition: border-color 0.08s ease;
      }
      .search-input::placeholder { color: var(--text-muted); }
      .search-input:focus { border-color: var(--accent); }

      /* ===== Article (item detail) ===== */
      .article-header { margin-bottom: 24px; }
      .article-title {
        font-size: 32px; font-weight: 600; letter-spacing: -0.02em;
        line-height: 1.2; margin-bottom: 12px;
      }
      .article-summary { color: var(--text-secondary); font-size: 16px; margin-bottom: 16px; }
      .article-meta {
        display: flex; flex-wrap: wrap; align-items: center; gap: 12px;
        padding: 12px 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        font-size: 13px; color: var(--text-muted);
      }
      .article-meta-item { display: inline-flex; align-items: center; gap: 6px; }
      .article-meta-key { color: var(--text-muted); }
      .article-meta-val { color: var(--text-secondary); }

      /* ===== Prose (rendered markdown) ===== */
      .prose { font-size: 15px; line-height: 1.7; color: var(--text); padding-top: 24px; }
      .prose > * + * { margin-top: 16px; }
      .prose h1 { font-size: 24px; font-weight: 600; letter-spacing: -0.01em; margin-top: 32px; }
      .prose h2 {
        font-size: 18px; font-weight: 600; letter-spacing: -0.01em;
        margin-top: 32px; padding-bottom: 6px;
        border-bottom: 1px solid var(--border);
      }
      .prose h3 { font-size: 15px; font-weight: 600; margin-top: 24px; }
      .prose p { color: var(--text); }
      .prose a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
      .prose a:hover { text-decoration-thickness: 2px; }
      .prose ul, .prose ol { padding-left: 22px; }
      .prose li + li { margin-top: 4px; }
      .prose code {
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px;
        background: var(--bg-card);
        padding: 1.5px 5px; border-radius: 3px;
        border: 1px solid var(--border);
      }
      .prose pre {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 14px 16px;
        overflow-x: auto;
        font-size: 12.5px; line-height: 1.55;
      }
      .prose pre code { background: none; border: none; padding: 0; font-size: inherit; }
      .prose blockquote {
        border-left: 2px solid var(--accent);
        padding: 4px 0 4px 16px;
        color: var(--text-secondary);
      }
      .prose table {
        width: 100%; border-collapse: collapse;
        font-size: 13px;
        border: 1px solid var(--border); border-radius: var(--radius);
        overflow: hidden;
      }
      .prose th, .prose td {
        text-align: left; padding: 8px 12px;
        border-bottom: 1px solid var(--border);
      }
      .prose th {
        background: var(--bg-card);
        font-weight: 600; color: var(--text-secondary);
        font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em;
      }
      .prose tr:last-child td { border-bottom: none; }
      .prose hr { border: none; height: 1px; background: var(--border); margin: 24px 0; }

      /* ===== Item detail layout (article + sticky thread) ===== */
      .item-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(360px, 400px);
        gap: 40px;
        max-width: 1240px;
        margin: 0 auto;
        padding: 24px 28px 80px;
        align-items: start;
      }
      .item-article { min-width: 0; }

      .thread-panel {
        position: sticky;
        top: 48px;
        height: calc(100vh - 48px);
        display: flex; flex-direction: column;
        padding: 16px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
      }
      .thread-panel-header {
        display: flex; align-items: center; gap: 8px;
        padding: 4px 4px 12px;
        border-bottom: 1px solid var(--border);
        font-size: 12px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        flex-shrink: 0;
      }
      .thread-panel-header .count {
        color: var(--text-muted); font-weight: 400;
        background: var(--bg); padding: 1px 6px; border-radius: 999px;
        font-size: 10px; text-transform: none; letter-spacing: 0;
      }
      .thread-scroll {
        flex: 1; min-height: 0;
        overflow-y: auto;
        padding: 14px 0 8px;
        margin: 0 -4px;
      }
      .thread-scroll::-webkit-scrollbar { width: 6px; }
      .thread-scroll::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.08); border-radius: 3px;
      }
      .thread-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(255,255,255,0.16);
      }
      .thread-composer-wrap { flex-shrink: 0; padding-top: 8px; }

      @media (max-width: 980px) {
        .item-layout {
          grid-template-columns: minmax(0, 1fr);
          gap: 28px;
        }
        .thread-panel {
          position: static;
          height: auto;
          max-height: none;
        }
        .thread-scroll {
          overflow-y: visible;
          max-height: none;
        }
      }

      .live-dot {
        display: inline-block;
        width: 6px; height: 6px; border-radius: 50%;
        background: #4ADE80;
        box-shadow: 0 0 8px rgba(74,222,128,0.6);
        animation: live-pulse 2s ease-in-out infinite;
        margin-left: 4px;
      }
      @keyframes live-pulse {
        0%, 100% { opacity: 0.6; transform: scale(1); }
        50%      { opacity: 1;   transform: scale(1.2); }
      }

      .thread-list {
        list-style: none; padding: 0; margin: 0;
        display: flex; flex-direction: column; gap: 14px;
      }
      .thread-message {
        display: flex; gap: 10px;
        padding: 4px;
      }
      .thread-avatar { flex-shrink: 0; padding-top: 1px; }
      .thread-body { flex: 1; min-width: 0; }
      .thread-meta {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        font-size: 11.5px; color: var(--text-muted);
        margin-bottom: 4px;
      }
      .thread-author { color: var(--text); font-weight: 500; font-size: 13px; }
      .thread-edited, .thread-via { font-style: italic; }
      .thread-actions { margin-left: auto; }
      .thread-action-btn {
        font-size: 11px; color: var(--text-muted);
        padding: 2px 6px; border-radius: 4px;
      }
      .thread-action-btn:hover { color: var(--danger); background: rgba(229,72,77,0.08); }
      .thread-content {
        color: var(--text); font-size: 13.5px; line-height: 1.55;
        word-wrap: break-word; overflow-wrap: break-word;
      }
      .thread-content > * + * { margin-top: 6px; }
      .thread-content code {
        font-family: 'JetBrains Mono', monospace; font-size: 12px;
        background: var(--bg); padding: 1px 4px; border-radius: 3px;
        border: 1px solid var(--border-strong);
      }
      .thread-content pre {
        background: var(--bg); border: 1px solid var(--border-strong);
        border-radius: 4px; padding: 10px; overflow-x: auto;
        font-size: 12px;
      }
      .thread-content p { margin: 0; }
      .thread-content a { color: var(--accent); }

      .thread-empty {
        text-align: center; padding: 32px 16px;
        color: var(--text-muted); font-size: 13px;
      }

      .reply-composer {
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        background: var(--bg-input);
        padding: 10px 12px;
        transition: border-color 0.08s ease;
      }
      .reply-composer:focus-within { border-color: var(--accent); }
      .reply-input {
        width: 100%; border: none; outline: none;
        background: transparent; color: var(--text);
        font: inherit; font-size: 13.5px; line-height: 1.5;
        resize: none; min-height: 44px;
      }
      .reply-input::placeholder { color: var(--text-muted); }
      .reply-footer {
        display: flex; align-items: center; justify-content: space-between;
        margin-top: 6px;
      }
      .reply-hint { font-size: 11px; color: var(--text-muted); }
      .reply-submit {
        background: var(--accent); color: white;
        padding: 5px 12px; border-radius: 5px;
        font-size: 12px; font-weight: 500;
      }
      .reply-submit:hover { background: #7470ff; }
      .reply-submit:disabled {
        background: rgba(255,255,255,0.05); color: var(--text-muted);
        cursor: not-allowed;
      }

      /* ===== Auth (signup / login / show token) ===== */
      .auth-shell {
        min-height: 100vh;
        display: flex; align-items: center; justify-content: center;
        padding: 24px;
        background: var(--bg);
      }
      .auth-card {
        width: 100%; max-width: 420px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px 28px;
      }
      .auth-card-wide { max-width: 540px; }
      .auth-brand {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 28px;
      }
      .auth-brand-name { font-weight: 600; font-size: 14px; letter-spacing: -0.01em; }
      .auth-title {
        font-size: 22px; font-weight: 600; letter-spacing: -0.015em;
        margin-bottom: 6px;
      }
      .auth-subtitle {
        color: var(--text-muted); font-size: 14px; line-height: 1.55;
        margin-bottom: 22px;
      }
      .auth-subtitle strong { color: var(--text); font-weight: 600; }
      .auth-form { display: flex; flex-direction: column; gap: 0; }
      .auth-label {
        font-size: 12px; font-weight: 500;
        color: var(--text-secondary);
        margin-bottom: 6px;
      }
      .auth-input {
        height: 40px; padding: 0 12px;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        font-size: 14px; color: var(--text);
        outline: none;
        transition: border-color 0.08s ease;
      }
      .auth-input:focus { border-color: var(--accent); }
      .auth-input-error { border-color: var(--danger); }
      .auth-hint {
        font-size: 11.5px; color: var(--text-muted);
        margin-top: 6px;
      }
      .auth-hint code {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
      }
      .auth-error {
        font-size: 12.5px; color: var(--danger);
        margin-top: 8px;
      }
      .auth-submit {
        margin-top: 18px;
        height: 40px;
        background: var(--accent); color: white;
        border-radius: var(--radius);
        font-size: 14px; font-weight: 500;
      }
      .auth-submit:hover { background: #7470ff; }
      .auth-submit:disabled {
        background: rgba(255,255,255,0.06); color: var(--text-muted);
        cursor: not-allowed;
      }
      .auth-secondary {
        height: 40px; padding: 0 16px;
        background: transparent;
        border: 1px solid var(--border-strong);
        border-radius: var(--radius);
        font-size: 13px; font-weight: 500;
        color: var(--text);
        transition: background 0.08s ease, color 0.08s ease;
      }
      .auth-secondary:hover { background: rgba(255,255,255,0.04); }
      .auth-secondary.copied {
        background: rgba(74,222,128,0.10);
        border-color: rgba(74,222,128,0.4);
        color: #4ADE80;
      }
      .auth-footer {
        margin-top: 24px;
        text-align: center;
        font-size: 13px;
        color: var(--text-muted);
      }
      .auth-link { color: var(--accent); }
      .auth-link:hover { text-decoration: underline; }

      .token-display {
        background: var(--bg);
        border: 1.5px solid var(--accent-dim);
        border-radius: var(--radius);
        padding: 14px 16px;
        margin-bottom: 14px;
        overflow-wrap: break-word; word-break: break-all;
        user-select: all;
      }
      .token-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px; color: var(--accent);
        letter-spacing: 0.01em;
      }
      .auth-actions {
        display: flex; gap: 10px; align-items: stretch;
        margin-top: 4px;
      }
      .auth-actions form { flex: 1; display: flex; }
      .auth-actions .auth-submit { width: 100%; margin-top: 0; }
      .auth-divider {
        height: 1px; background: var(--border);
        margin: 24px -4px;
      }
      .auth-cli-hint-title {
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 8px;
      }
      .auth-cli-block {
        background: var(--bg); border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 10px 12px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-secondary);
      }

      /* ===== Empty state ===== */
      .empty {
        text-align: center; padding: 48px 24px;
        color: var(--text-muted); font-size: 13px;
        border: 1px dashed var(--border); border-radius: var(--radius);
      }

      /* ===== Banner ===== */
      .banner {
        padding: 12px 16px; border-radius: var(--radius);
        background: var(--bg-card); border: 1px solid var(--border);
        font-size: 13px; color: var(--text-secondary);
        margin-bottom: 16px;
      }
      .banner code {
        font-family: 'JetBrains Mono', monospace; font-size: 12px;
        background: var(--bg); padding: 1px 5px; border-radius: 3px;
        border: 1px solid var(--border-strong);
      }
      .banner-warning { border-color: rgba(242,201,76,0.30); }

      /* ===== Flash ===== */
      .flash-fixed {
        position: fixed; bottom: 16px; right: 16px; z-index: 50;
        padding: 10px 14px; border-radius: var(--radius);
        background: var(--bg-card); border: 1px solid var(--border-strong);
        font-size: 13px; color: var(--text);
        box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      }
      .flash-error { border-color: var(--danger); color: var(--danger); }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
