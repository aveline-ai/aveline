# Self-hosting config for docker compose (env_file format: KEY=value, no `export`).
#   cp .env.docker.example .env
# Then: docker compose up -d --build
# (The dev-workflow example is .env.example; this one is for compose.yaml.)

# --- Postgres (the compose `db` service) ---------------------------------
# Any strong string; used by both the db container and DATABASE_URL below.
POSTGRES_PASSWORD=change-me

# The app connects to the compose `db` service by hostname. Keep user/db as
# `aveline` to match compose.yaml; keep the password in sync with above.
DATABASE_URL=ecto://aveline:change-me@db/aveline

# --- Secrets -------------------------------------------------------------
# Phoenix session/signing key. Generate: mix phx.gen.secret
SECRET_KEY_BASE=

# 32-byte key that encrypts data source passwords at rest.
# Generate: openssl rand -base64 32
CLOAK_KEY=

# --- Host / networking ---------------------------------------------------
# The hostname you serve from (localhost, or your Tailscale machine name).
PHX_HOST=localhost

# Container listen port (compose maps 127.0.0.1:7151 -> this).
PORT=4000

# Allowed WebSocket origins (comma-separated, scheme included). Must match how
# you reach the app in the browser, or LiveView reload-loops.
#   local:    http://localhost:7151
#   tailnet:  https://your-machine.your-tailnet.ts.net
CHECK_ORIGIN=http://localhost:7151
