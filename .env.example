# Copy to .env (gitignored) and fill in real values for local dev.
# Source it before running the server, e.g.:
#   set -a; source .env; set +a; iex -S mix phx.server

# Postgres — point at Supabase (use the Session pooler connection string from
# the Supabase dashboard) or any other Postgres. If unset, dev.exs falls back
# to postgres@localhost/aveline_dev.
# export DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres"

# Sentry — optional in dev. Leave unset to no-op; set to your DSN to ship
# dev errors + logs to Sentry.
# export SENTRY_DSN="https://<key>@<org>.ingest.sentry.io/<project-id>"
